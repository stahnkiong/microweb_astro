---
interface Props {
  height?: string;
}

const { height = '600px' } = Astro.props;
---

<div
  class="telemetry-validator-container flex flex-col md:flex-row gap-8 p-6 md:p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl overflow-hidden transition-all duration-300 not-prose"
  style={`min-height: ${height};`}
>
  <!-- Control Panel (Inputs) -->
  <div class="flex-1 flex flex-col justify-between space-y-6">
    <div>
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
          ></path>
        </svg>
        Edge Telemetry & ML Optimizer
      </h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">
        Fine-tune machine learning confidence filters and image processing parameters to optimize frame latency and prediction accuracy metrics in real time.
      </p>
    </div>

    <!-- Inputs -->
    <div class="space-y-6">
      <!-- Input 1: Model Format -->
      <div class="space-y-2">
        <label for="modelFormat" class="block text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          Model Inference Precision Target
        </label>
        <select
          id="modelFormat"
          class="w-full p-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-sm text-neutral-800 dark:text-neutral-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
        >
          <option value="int8">Compiled INT8 Quantized (Edge Optimized)</option>
          <option value="fp16">Compiled FP16 Floating Point (Standard Matrix)</option>
          <option value="fp32">Unoptimized FP32 Core Weights (Heavy Compute)</option>
        </select>
      </div>

      <!-- Input 2: Confidence Threshold -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          <label for="confidenceSlider">Model Confidence Filter Threshold</label>
          <span id="confidenceLabel" class="text-primary font-mono text-sm font-bold">0.75</span>
        </div>
        <input
          type="range"
          id="confidenceSlider"
          min="50"
          max="95"
          value="75"
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-[10px] text-neutral-400 font-mono">
          <span>0.50 (Permissive)</span>
          <span>0.95 (Strict)</span>
        </div>
      </div>

      <!-- Input 3: Worker Cores -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          <label for="workerSlider">Parallel Worker Processes</label>
          <span id="workerLabel" class="text-primary font-mono text-sm font-bold">4 Cores</span>
        </div>
        <input
          type="range"
          id="workerSlider"
          min="1"
          max="8"
          value="4"
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-[10px] text-neutral-400 font-mono">
          <span>1 Core</span>
          <span>8 Cores (Max Compute)</span>
        </div>
      </div>
    </div>

    <!-- Info Footer -->
    <div class="border-t border-neutral-100 dark:border-neutral-800 pt-4 text-xs text-neutral-400 flex items-center gap-1.5">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 text-neutral-400 flex-shrink-0"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <span>Real-time metrics validated against UNIMAS remote sensing agricultural benchmarks.</span>
    </div>
  </div>

  <!-- Output Panel -->
  <div class="flex-1 flex flex-col justify-between p-6 rounded-xl bg-neutral-50 dark:bg-neutral-950 border border-neutral-150 dark:border-neutral-850">
    <div class="text-xs font-bold uppercase tracking-wider text-neutral-400 flex items-center gap-2 mb-4">
      <span class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse" id="pipeline-status-dot"></span>
      ML Performance Matrix
    </div>

    <div class="grid grid-cols-2 gap-4 my-auto py-4">
      <!-- Precision -->
      <div class="p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-sm text-center">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500 block mb-1">
          Calculated Precision
        </span>
        <div id="precisionOutput" class="text-2xl font-mono font-bold text-primary">
          0.92
        </div>
      </div>

      <!-- Recall -->
      <div class="p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-sm text-center">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500 block mb-1">
          Calculated Recall
        </span>
        <div id="recallOutput" class="text-2xl font-mono font-bold text-primary">
          0.89
        </div>
      </div>

      <!-- F1 Score -->
      <div class="p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-sm text-center">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500 block mb-1">
          F1-Score Validation
        </span>
        <div id="f1Output" class="text-2xl font-mono font-bold text-neutral-800 dark:text-white">
          0.90
        </div>
      </div>

      <!-- Latency -->
      <div class="p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-sm text-center">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500 block mb-1">
          Inference Latency
        </span>
        <div id="latencyOutput" class="text-2xl font-mono font-bold text-emerald-500 dark:text-emerald-400">
          14 ms
        </div>
      </div>
    </div>

    <!-- Output Badge -->
    <div class="border-t border-neutral-200/50 dark:border-neutral-800/50 pt-4 text-center">
      <div class="text-xs font-semibold text-neutral-400 mb-2">Pipeline Optimization Status</div>
      <div
        id="statusBadge"
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-emerald-500/10 text-emerald-800 dark:text-emerald-400 border-emerald-500/20"
      >
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        OPTIMIZED PIPELINE
      </div>
    </div>
  </div>
</div>

<script>
  function initTelemetryValidator() {
    const formatSelect = document.getElementById('modelFormat') as HTMLSelectElement;
    const confidenceSlider = document.getElementById('confidenceSlider') as HTMLInputElement;
    const workerSlider = document.getElementById('workerSlider') as HTMLInputElement;

    const confidenceLabel = document.getElementById('confidenceLabel');
    const workerLabel = document.getElementById('workerLabel');

    const precisionOutputNode = document.getElementById('precisionOutput');
    const recallOutputNode = document.getElementById('recallOutput');
    const f1OutputNode = document.getElementById('f1Output');
    const latencyOutputNode = document.getElementById('latencyOutput');
    const statusBadgeNode = document.getElementById('statusBadge');
    const pipelineStatusDot = document.getElementById('pipeline-status-dot');

    if (!formatSelect || !confidenceSlider || !workerSlider) return;

    function calculateTelemetryMetrics() {
      const format = formatSelect.value;
      const confidence = parseInt(confidenceSlider.value) / 100;
      const workers = parseInt(workerSlider.value);

      // Update slider UI labels immediately
      if (confidenceLabel) confidenceLabel.textContent = confidence.toFixed(2);
      if (workerLabel) workerLabel.textContent = `${workers} Core${workers > 1 ? 's' : ''}`;

      // Base performance variables matching the summit slides
      let basePrecision = 0.92;
      let baseRecall = 0.89;
      let baseLatency = 24; // milliseconds

      // Adjust metrics based on model selection configurations
      if (format === 'int8') {
        baseLatency = 14;
        basePrecision -= 0.01;
        baseRecall -= 0.01;
      } else if (format === 'fp32') {
        baseLatency = 58;
        basePrecision += 0.01;
        baseRecall += 0.02;
      }

      // Process adjustments for slider threshold variations
      const confidenceOffset = confidence - 0.75;
      basePrecision += confidenceOffset * 0.15;
      baseRecall -= confidenceOffset * 0.25;

      // Apply compute changes from processing core counts
      baseLatency = Math.max(4, baseLatency / (workers * 0.65));

      // Safeguard metrics boundaries
      basePrecision = Math.min(0.99, Math.max(0.6, basePrecision));
      baseRecall = Math.min(0.99, Math.max(0.5, baseRecall));
      const f1Score = (2 * basePrecision * baseRecall) / (basePrecision + baseRecall);

      // Update UI elements with processed calculation values
      if (precisionOutputNode) precisionOutputNode.textContent = basePrecision.toFixed(2);
      if (recallOutputNode) recallOutputNode.textContent = baseRecall.toFixed(2);
      if (f1OutputNode) f1OutputNode.textContent = f1Score.toFixed(2);
      if (latencyOutputNode) {
        const roundedLatency = Math.round(baseLatency);
        latencyOutputNode.textContent = `${roundedLatency} ms`;

        if (roundedLatency > 40) {
          latencyOutputNode.className = 'text-2xl font-mono font-bold text-red-500 dark:text-red-400';
        } else if (roundedLatency > 20) {
          latencyOutputNode.className = 'text-2xl font-mono font-bold text-amber-500 dark:text-amber-400';
        } else {
          latencyOutputNode.className = 'text-2xl font-mono font-bold text-emerald-500 dark:text-emerald-400';
        }
      }

      if (statusBadgeNode) {
        if (baseLatency > 40) {
          statusBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-rose-500/10 text-rose-800 dark:text-rose-400 border-rose-500/20';
          statusBadgeNode.innerHTML = '<span class="w-2 h-2 rounded-full bg-rose-500"></span>LATENCY CRITICAL CORDS';
          if (pipelineStatusDot) pipelineStatusDot.className = 'w-2.5 h-2.5 rounded-full bg-rose-500 animate-pulse';
        } else if (f1Score < 0.82) {
          statusBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-amber-500/10 text-amber-800 dark:text-amber-400 border-amber-500/20';
          statusBadgeNode.innerHTML = '<span class="w-2 h-2 rounded-full bg-amber-500"></span>ACCURACY ACCELERATED DROP';
          if (pipelineStatusDot) pipelineStatusDot.className = 'w-2.5 h-2.5 rounded-full bg-amber-500 animate-pulse';
        } else {
          statusBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-emerald-500/10 text-emerald-800 dark:text-emerald-400 border-emerald-500/20';
          statusBadgeNode.innerHTML =
            '<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>OPTIMIZED PIPELINE';
          if (pipelineStatusDot) pipelineStatusDot.className = 'w-2.5 h-2.5 rounded-full bg-primary animate-pulse';
        }
      }
    }

    // Bind low-overhead event listeners
    formatSelect.addEventListener('change', calculateTelemetryMetrics);
    confidenceSlider.addEventListener('input', calculateTelemetryMetrics);
    workerSlider.addEventListener('input', calculateTelemetryMetrics);

    // Initial run
    calculateTelemetryMetrics();
  }

  // Setup execution on load and page transition
  document.addEventListener('DOMContentLoaded', initTelemetryValidator);
  document.addEventListener('astro:page-load', initTelemetryValidator);
</script>
