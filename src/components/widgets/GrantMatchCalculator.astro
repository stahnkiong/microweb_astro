---
interface Props {
  height?: string;
}

const { height = '600px' } = Astro.props;
---

<div
  class="grant-match-calculator-container flex flex-col md:flex-row gap-8 p-6 md:p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl overflow-hidden transition-all duration-300 not-prose"
  style={`min-height: ${height};`}
>
  <!-- Control Panel (Inputs) -->
  <div class="flex-1 flex flex-col justify-between space-y-6">
    <div>
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        URIIS 2026 Innovation Alignment
      </h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">
        Configure research parameters to estimate matching grant capabilities under Sarawak SDEC and i-CATS mandates.
      </p>
    </div>

    <!-- Inputs -->
    <div class="space-y-6">
      <!-- Input 1: Research Domain -->
      <div class="space-y-2">
        <label for="researchDomain" class="block text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          Research Domain & Focus
        </label>
        <select
          id="researchDomain"
          class="w-full p-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-sm text-neutral-800 dark:text-neutral-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
        >
          <option value="sci-tech">Science & Technology (AI, Smart Cities, IoT)</option>
          <option value="social-sci">Social Sciences & Humanities</option>
        </select>
      </div>

      <!-- Input 2: Budget -->
      <div class="space-y-2">
        <label for="projectBudget" class="block text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          Total Intended R&D Capital (RM)
        </label>
        <input
          type="number"
          id="projectBudget"
          value="100000"
          min="10000"
          step="5000"
          class="w-full p-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-sm text-neutral-800 dark:text-neutral-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors font-mono"
        />
      </div>

      <!-- Input 3: Regional Alignment Vectors -->
      <div class="space-y-3">
        <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          Regional Alignment Vectors
        </span>
        <div class="space-y-2">
          <label class="flex items-center text-sm text-neutral-700 dark:text-neutral-300 cursor-pointer">
            <input type="checkbox" id="vectorSdec" checked class="mr-2.5 h-4 w-4 rounded border-neutral-300 text-primary focus:ring-primary accent-primary" />
            <span>Corresponds with SDEC Digital Mandates</span>
          </label>
          <label class="flex items-center text-sm text-neutral-700 dark:text-neutral-300 cursor-pointer">
            <input type="checkbox" id="vectorIcats" checked class="mr-2.5 h-4 w-4 rounded border-neutral-300 text-primary focus:ring-primary accent-primary" />
            <span>Partnered with i-CATS / UNIMAS Pipelines</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Info Footer -->
    <div class="border-t border-neutral-100 dark:border-neutral-800 pt-4 text-xs text-neutral-400 flex items-center gap-1.5">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 text-neutral-400 flex-shrink-0"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <span>Calculations aligned with the i-CATS Research & Innovation Master Plan (2026–2030).</span>
    </div>
  </div>

  <!-- Output Panel -->
  <div class="flex-1 flex flex-col justify-between p-6 rounded-xl bg-neutral-50 dark:bg-neutral-950 border border-neutral-150 dark:border-neutral-850">
    <div class="text-xs font-bold uppercase tracking-wider text-neutral-400 flex items-center gap-2 mb-4">
      <span class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse" id="compliance-dot"></span>
      Grant Match Analysis
    </div>

    <div class="my-auto py-6 space-y-8">
      <!-- Output 1: Grant Match Allocation -->
      <div class="text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
          Calculated Grant Match Allocation
        </span>
        <div id="grantOutput" class="mt-2 text-4xl font-extrabold text-primary font-mono tracking-tight transition-all duration-300">
          RM 20,000
        </div>
      </div>

      <!-- Output 2: Net Corporate Capital -->
      <div class="space-y-2 p-4 bg-white dark:bg-neutral-900 rounded-lg border border-neutral-200/60 dark:border-neutral-800/80 shadow-sm text-center">
        <span class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
          Net Corporate Capital Requirement
        </span>
        <div id="netBudgetOutput" class="mt-1 text-2xl font-bold text-neutral-800 dark:text-white font-mono">
          RM 80,000
        </div>
      </div>
    </div>

    <!-- Output 3: Compliance Status Badge -->
    <div class="border-t border-neutral-200/50 dark:border-neutral-800/50 pt-4 text-center">
      <div class="text-xs font-semibold text-neutral-400 mb-2">Strategic Compliance Status</div>
      <div
        id="complianceBadge"
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-emerald-500/10 text-emerald-800 dark:text-emerald-400 border-emerald-500/20"
      >
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        HIGH MATCH PROBABILITY
      </div>
    </div>
  </div>
</div>

<script>
  function initGrantMatchCalculator() {
    const domainSelect = document.getElementById('researchDomain') as HTMLSelectElement;
    const budgetInput = document.getElementById('projectBudget') as HTMLInputElement;
    const vectorSdecCheckbox = document.getElementById('vectorSdec') as HTMLInputElement;
    const vectorIcatsCheckbox = document.getElementById('vectorIcats') as HTMLInputElement;

    const grantOutputNode = document.getElementById('grantOutput');
    const netBudgetOutputNode = document.getElementById('netBudgetOutput');
    const complianceBadgeNode = document.getElementById('complianceBadge');
    const complianceDot = document.getElementById('compliance-dot');

    if (!domainSelect || !budgetInput || !vectorSdecCheckbox || !vectorIcatsCheckbox) return;

    function calculateGrantMetrics() {
      const domain = domainSelect.value;
      const budget = parseFloat(budgetInput.value) || 0;
      const isSdecAligned = vectorSdecCheckbox.checked;
      const isIcatsAligned = vectorIcatsCheckbox.checked;

      const maxGrantCap = domain === 'sci-tech' ? 20000 : 10000;

      // Apply a standard 20% co-funding match ratio
      let calculatedGrant = budget * 0.2;
      if (calculatedGrant > maxGrantCap) {
        calculatedGrant = maxGrantCap;
      }

      // Dynamic penalty reduction if regional alignment conditions aren't satisfied
      if (!isSdecAligned || !isIcatsAligned) {
        calculatedGrant *= 0.5;
      }

      const netCorporateCost = budget - calculatedGrant;

      // Stream results directly to UI nodes
      if (grantOutputNode) {
        grantOutputNode.textContent = `RM ${calculatedGrant.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
      }
      if (netBudgetOutputNode) {
        netBudgetOutputNode.textContent = `RM ${netCorporateCost.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
      }

      if (complianceBadgeNode) {
        if (calculatedGrant === 0) {
          complianceBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-rose-500/10 text-rose-800 dark:text-rose-400 border-rose-500/20';
          complianceBadgeNode.innerHTML = '<span class="w-2 h-2 rounded-full bg-rose-500"></span>NON-COMPLIANT';
          if (complianceDot) complianceDot.className = 'w-2.5 h-2.5 rounded-full bg-rose-500 animate-pulse';
        } else if (!isSdecAligned || !isIcatsAligned) {
          complianceBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-amber-500/10 text-amber-800 dark:text-amber-400 border-amber-500/20';
          complianceBadgeNode.innerHTML =
            '<span class="w-2 h-2 rounded-full bg-amber-400"></span>MODERATE COMPLIANCE';
          if (complianceDot) complianceDot.className = 'w-2.5 h-2.5 rounded-full bg-amber-500 animate-pulse';
        } else {
          complianceBadgeNode.className =
            'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border bg-emerald-500/10 text-emerald-800 dark:text-emerald-400 border-emerald-500/20';
          complianceBadgeNode.innerHTML =
            '<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>HIGH MATCH PROBABILITY';
          if (complianceDot) complianceDot.className = 'w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse';
        }
      }
    }

    // Bind low-overhead event listeners
    domainSelect.addEventListener('change', calculateGrantMetrics);
    budgetInput.addEventListener('input', calculateGrantMetrics);
    vectorSdecCheckbox.addEventListener('change', calculateGrantMetrics);
    vectorIcatsCheckbox.addEventListener('change', calculateGrantMetrics);

    // Run initial calculations
    calculateGrantMetrics();
  }

  // Setup execution on load and page transition
  document.addEventListener('DOMContentLoaded', initGrantMatchCalculator);
  document.addEventListener('astro:page-load', initGrantMatchCalculator);
</script>
