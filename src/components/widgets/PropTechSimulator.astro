---
interface Props {
  height?: string;
}

const { height = '650px' } = Astro.props;
---

<div
  class="proptech-simulator-container flex flex-col lg:flex-row gap-8 p-6 md:p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl overflow-hidden transition-all duration-300 not-prose"
  style={`min-height: ${height};`}
>
  <!-- Input Control Panel -->
  <div class="flex-1 flex flex-col justify-between space-y-6">
    <div>
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
          ></path>
        </svg>
        Property Portfolio Metrics
      </h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">
        Adjust the financial sliders to evaluate conversion recovery models.
      </p>
    </div>

    <div class="space-y-6">
      <!-- Input 1: Digital Leads -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="leads-slider" class="text-neutral-700 dark:text-neutral-300">Annual Digital Leads</label>
          <span id="leads-value" class="text-primary font-mono text-base">100</span>
        </div>
        <input
          type="range"
          id="leads-slider"
          min="100"
          max="5000"
          step="100"
          value="200"
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>100 leads</span>
          <span>10,000 leads</span>
        </div>
      </div>

      <!-- Input 2: Asset Price -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="asset-slider" class="text-neutral-700 dark:text-neutral-300">Avg Property Value (RM)</label>
          <span id="asset-value" class="text-primary font-mono text-base">450,000</span>
        </div>
        <input
          type="range"
          id="asset-slider"
          min="100000"
          max="1000000"
          step="10000"
          value="450000"
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>RM 100k</span>
          <span>RM 1M+</span>
        </div>
      </div>

      <!-- Input 3: Net Profit Margin -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="margin-slider" class="text-neutral-700 dark:text-neutral-300">Net Profit Margin (%)</label>
          <span id="margin-value" class="text-primary font-mono text-base">4.5%</span>
        </div>
        <input
          type="range"
          id="margin-slider"
          min="2.0"
          max="20.0"
          step="0.5"
          value="10"
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>2.0%</span>
          <span>20.0%</span>
        </div>
      </div>
    </div>

    <div
      class="border-t border-neutral-100 dark:border-neutral-800 pt-4 text-xs text-neutral-400 flex items-center gap-1.5"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 text-neutral-400 fill-none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>Dynamic PropTech ROI model mapped for custom software evaluation.</span>
    </div>
  </div>

  <!-- Output Dashboard Display -->
  <div
    class="flex-1 flex flex-col justify-between p-6 rounded-xl bg-neutral-50 dark:bg-neutral-950 border border-neutral-150 dark:border-neutral-850"
  >
    <div class="text-xs font-bold uppercase tracking-wider text-neutral-400 flex items-center gap-2 mb-4">
      <span class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse"></span>
      Financial Comparison Dashboard
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-auto">
      <!-- Architecture Model 1 -->
      <div
        class="p-4 rounded-lg bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 space-y-4"
      >
        <div class="text-center border-b border-neutral-100 dark:border-neutral-800 pb-2">
          <span class="text-xs font-bold text-neutral-400 uppercase tracking-wider">Option 1: Basic Gateway</span>
          <p class="text-xs text-neutral-500 mt-0.5">1.5% Baseline Lift</p>
        </div>
        <div class="text-center">
          <span class="text-[10px] uppercase font-semibold text-neutral-400 tracking-wider">Recovered Units</span>
          <div id="opt1-units" class="text-2xl font-extrabold text-neutral-800 dark:text-white font-mono">39</div>
        </div>
        <div class="text-center">
          <span class="text-[10px] uppercase font-semibold text-neutral-400 tracking-wider">Net Profit Recovered</span>
          <div id="opt1-profit" class="text-xl font-bold text-emerald-500 font-mono">RM 263,250</div>
        </div>
        <div
          class="text-center bg-neutral-50 dark:bg-neutral-950 p-2 rounded border border-neutral-100 dark:border-neutral-850"
        >
          <span class="text-[9px] uppercase font-bold text-neutral-400 tracking-wider">Projected ROI Yield</span>
          <div id="opt1-roi" class="text-xl font-black text-primary font-mono">30x</div>
        </div>
      </div>

      <!-- Architecture Model 2 -->
      <div
        class="p-4 rounded-lg bg-neutral-900 dark:bg-neutral-850 border border-primary/30 space-y-4 shadow-md relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 bg-primary text-white text-[8px] font-black uppercase px-2 py-0.5 tracking-wider rounded-bl"
        >
          Adaptive
        </div>
        <div class="text-center border-b border-neutral-800 pb-2">
          <span class="text-xs font-bold text-neutral-300 uppercase tracking-wider">Option 2: Optimized AI</span>
          <p class="text-xs text-neutral-400 mt-0.5">3.5% Optimized Lift</p>
        </div>
        <div class="text-center">
          <span class="text-[10px] uppercase font-semibold text-neutral-400 tracking-wider">Recovered Units</span>
          <div id="opt2-units" class="text-2xl font-extrabold text-white font-mono">91</div>
        </div>
        <div class="text-center">
          <span class="text-[10px] uppercase font-semibold text-neutral-400 tracking-wider">Net Profit Recovered</span>
          <div id="opt2-profit" class="text-xl font-bold text-emerald-400 font-mono">RM 614,250</div>
        </div>
        <div class="text-center bg-black p-2 rounded border border-neutral-800">
          <span class="text-[9px] uppercase font-bold text-neutral-400 tracking-wider">Projected ROI Yield</span>
          <div id="opt2-roi" class="text-xl font-black text-accent font-mono">46x</div>
        </div>
      </div>
    </div>

    <div
      class="border-t border-neutral-200/50 dark:border-neutral-800/50 pt-4 mt-4 text-[11px] text-neutral-400 italic text-center"
    >
      * Option 2 calculates localized processing efficiency variables including regional Foochow model training sets.
    </div>
  </div>
</div>

<script>
  function initRoiSimulator() {
    const leadsSlider = document.getElementById('leads-slider') as HTMLInputElement;
    const assetSlider = document.getElementById('asset-slider') as HTMLInputElement;
    const marginSlider = document.getElementById('margin-slider') as HTMLInputElement;

    const leadsValue = document.getElementById('leads-value');
    const assetValue = document.getElementById('asset-value');
    const marginValue = document.getElementById('margin-value');

    const opt1Units = document.getElementById('opt1-units');
    const opt1Profit = document.getElementById('opt1-profit');
    const opt1Roi = document.getElementById('opt1-roi');

    const opt2Units = document.getElementById('opt2-units');
    const opt2Profit = document.getElementById('opt2-profit');
    const opt2Roi = document.getElementById('opt2-roi');

    if (!leadsSlider || !assetSlider || !marginSlider) return;

    function recomputeFinances() {
      const leads = parseInt(leadsSlider.value);
      const assetPrice = parseInt(assetSlider.value);
      const netMargin = parseFloat(marginSlider.value) / 100;

      if (leadsValue) leadsValue.textContent = leads.toLocaleString();
      if (assetValue) assetValue.textContent = assetPrice.toLocaleString();
      if (marginValue) marginValue.textContent = (netMargin * 100).toFixed(1) + '%';

      const u1 = Math.round(leads * 0.015);
      const p1 = Math.round(u1 * assetPrice * netMargin);
      const r1 = Math.round(p1 / 8800);

      const u2 = Math.round(leads * 0.035);
      const p2 = Math.round(u2 * assetPrice * netMargin);
      const r2 = Math.round(p2 / 13200);

      if (opt1Units) opt1Units.textContent = u1.toLocaleString();
      if (opt1Profit) opt1Profit.textContent = 'RM ' + p1.toLocaleString();
      if (opt1Roi) opt1Roi.textContent = r1.toLocaleString() + 'x';

      if (opt2Units) opt2Units.textContent = u2.toLocaleString();
      if (opt2Profit) opt2Profit.textContent = 'RM ' + p2.toLocaleString();
      if (opt2Roi) opt2Roi.textContent = r2.toLocaleString() + 'x';
    }

    leadsSlider.addEventListener('input', recomputeFinances);
    assetSlider.addEventListener('input', recomputeFinances);
    marginSlider.addEventListener('input', recomputeFinances);

    recomputeFinances();
  }

  document.addEventListener('DOMContentLoaded', initRoiSimulator);
  document.addEventListener('astro:page-load', initRoiSimulator);
</script>
