---
import Banners3 from '~/components/widgets/Banners3.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import Stats2 from '~/components/widgets/Stats2.astro';
import PortFolioSummary from '../blog/PortFolioSummary.astro';
---

<Stats2
  stats={[
    { title: 'Global CDN Nodes', amount: '330+' },
    { title: 'Uptime Guarantee', amount: '99.9%' },
    { title: 'Mitigation Speed', amount: '< 3s' },
  ]}
/>

<Features2
  id="features"
  tagline="Why Power Your Business with Us?"
  title="<p class='font-normal'>Scalable, AI-Ready, & Custom-Built for Growth.</p>"
  items={[
    {
      title: 'Cost-Effective Scaling',
      description:
        'Start with a Minimum Viable Product (MVP) and scale as you grow. We prioritize flexible architectures that save resources and adapt to change.',
      icon: 'carbon:ibm-cloud-hpc',
    },
    {
      title: 'Tailored Business Logic',
      description:
        'Your business is unique. We build custom workflows and solutions that align perfectly with your specific operational needs and goals.',
      icon: 'carbon:development',
    },
    {
      title: 'Future-Proof & AI-Integrated',
      description:
        'Stay ahead with AI-ready web applications. We build systems designed to integrate modern machine learning and automation tools seamlessly.',
      icon: 'carbon:ml-model-reference',
    },
    {
      title: 'Seamless Ecosystem Integration',
      description:
        'Connect everything. We ensure your custom software plays nicely with your existing third-party APIs, cloud services, and legacy tools.',
      icon: 'carbon:ibm-api-connect',
    },
    {
      title: 'Transparent Collaboration',
      description:
        'We believe in two-way communication. You get clear insights into the technical health, while we align strictly with your business objectives.',
      icon: 'carbon:direct-link',
    },
    {
      title: 'Automated CI/CD Pipelines',
      description:
        'Deploy with confidence. Our automated pipelines ensure rapid updates, immediate bug fixes, and zero-downtime scalability.',
      icon: 'carbon:carbon-ui-builder',
    },
  ]}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</Features2>

<!-- <Banners/> -->

<!-- Content Widget **************** -->

<Content
  isReversed
  tagline="Your Long-Term Digital Partner"
  title="Grow With Confidence"
  subtitle="We don't just build; we maintain, optimize, and scale your digital presence."
  items={[
    {
      title: '13+ Years of Excellence',
      icon: 'carbon:badge',
      description: 'A proven track record of delivering robust software solutions across various industries.',
    },
    {
      title: 'Holistic Tech Expertise',
      icon: 'carbon:events',
      description: 'From AI and IoT to cloud infrastructure, we bring a full spectrum of technical knowledge.',
    },
    {
      title: 'Performance-Driven',
      icon: 'carbon:layers-external',
      description: 'Focusing on speed, security, and SEO to give you a competitive market edge.',
    },
    {
      title: 'Modern Tech Stack',
      icon: 'carbon:carbon-for-ibm-product',
      description: 'Utilizing the latest frameworks like Astro, React, and Tailwind for superior performance.',
    },
    {
      callToAction: {
        text: 'Start Your Project',
        variant: 'secondary',
        href: '#contact',
        icon: 'tabler:chevron-right',
      },
    },
  ]}
  image={{
    src: '~/assets/images/app_development_discussion.webp',
    alt: 'Sarawak development team discussing custom web application strategies',
  }}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</Content>

<Banners3 />

<PortFolioSummary />
