---
import Banners3 from '~/components/widgets/Banners3.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import Stats2 from '~/components/widgets/Stats2.astro';
import PortFolioSummary from '../blog/PortFolioSummary.astro';
---

<Stats2
  stats={[
    { title: 'Global Edge Cache Nodes', amount: '330+' },
    { title: 'System Uptime Target', amount: '99.9%' },
    { title: 'DDoS Mitigation Window', amount: '< 3s' },
  ]}
/>

<Features2
  id="features"
  tagline="Engineered for Performance"
  title="<p class='font-normal'>Eliminate Technical Debt via Zero-Management Infrastructure.</p>"
  items={[
    {
      title: 'Velocity Over Elegance (MVP)',
      description:
        'Validate operational requirements fast. We architect adaptive Minimum Viable Products that isolate and resolve high-friction bottlenecks within weeks, avoiding premature backend optimization.',
      icon: 'carbon:ibm-cloud-hpc',
    },
    {
      title: 'WhatsApp Integration Pipelines',
      description:
        'Meet users exactly where they live. We build autonomous workflows that turn incoming WhatsApp photos and text queries into direct, structured database entries natively.',
      icon: 'tabler:brand-whatsapp',
    },
    {
      title: 'Custom App Architecture',
      description:
        'As an experienced app developer company, we write decoupled, component-driven software frameworks designed to sustain high transaction volumes without runtime degradation.',
      icon: 'carbon:development',
    },
    {
      title: 'Decoupled API Connectivity',
      description:
        'Ensure system cohesion. We design and expose hardened REST or GraphQL API abstraction layers that connect modern edge deployments with complex legacy ERP environments.',
      icon: 'carbon:ibm-api-connect',
    },
    {
      title: 'Automated CI/CD Workflows',
      description:
        'Deploy production patches with confidence. Our automated pipelines run continuous verification testing via GitHub Actions, eliminating operational deployment drift.',
      icon: 'carbon:carbon-ui-builder',
    },
    {
      title: 'Local Digital Sovereignty',
      description:
        'Protect business data profiles. We route platform assets behind an enterprise Cloudflare Shield, keeping data workloads isolated and optimized across Malaysia regional centers.',
      icon: 'carbon:ml-model-reference',
    },
  ]}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</Features2>

<!-- Content Widget **************** -->

<Content
  isReversed
  tagline="Your Long-Term Systems Architect"
  title="Digital Infrastructure Built for Longevity"
  subtitle="We don't just build applications—we engineer, monitor, and scale secure backend environments that survive technology lifecycle shifts."
  items={[
    {
      title: '13+ Years of Production Stability',
      icon: 'carbon:badge',
      description:
        'A documented history of engineering robust enterprise web systems and custom application code across Malaysia since 2013.',
    },
    {
      title: 'Zero-Friction User Interfaces',
      icon: 'carbon:events',
      description:
        'Defeating tech-shock by utilizing familiar chat channels and computer vision pipelines to eliminate tedious manual key-in friction.',
    },
    {
      title: 'Performance-Driven Core Vitals',
      icon: 'carbon:layers-external',
      description:
        'Maximizing conversion velocity by prioritizing sub-second load times, strict layout boundary rules, and aggressive edge caching.',
    },
    {
      title: 'Modern Web Engineering',
      icon: 'carbon:carbon-for-ibm-product',
      description:
        'Leveraging high-performance, fast-compiling frameworks like Astro, React, and serverless edge functions for clean data delivery.',
    },
    {
      callToAction: {
        text: 'Consult an Architect',
        variant: 'secondary',
        href: '#contact',
        icon: 'tabler:chevron-right',
      },
    },
  ]}
  image={{
    src: '~/assets/images/app_development_discussion.webp',
    alt: 'MicroWeb systems engineers blueprinting custom app architecture in Kuching, Sarawak',
  }}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</Content>

<Banners3 />

<PortFolioSummary />
