---
interface Props {
  height?: string;
}

const { height = "600px" } = Astro.props;
---

<div class="generate-widget-container flex flex-col md:flex-row gap-8 p-6 md:p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl overflow-hidden transition-all duration-300" style={`min-height: ${height};`}>
  <!-- Control Panel (Inputs) -->
  <div class="flex-1 flex flex-col justify-between space-y-6">
    <div>
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
        Load Parameters
      </h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">
        Tune the sliders to simulate live traffic load on the sovereign server nodes.
      </p>
    </div>

    <!-- Inputs -->
    <div class="space-y-6">
      <!-- Input 1: Concurrent Scans -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="scans-slider" class="text-neutral-700 dark:text-neutral-300">Concurrent WhatsApp Webhooks / Hr</label>
          <span id="scans-value" class="text-primary font-mono text-base">5,000</span>
        </div>
        <div class="relative">
          <input 
            type="range" 
            id="scans-slider" 
            min="1000" 
            max="25000" 
            step="1000" 
            value="5000" 
            class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
          />
        </div>
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>1,000 requests</span>
          <span>25,000 requests</span>
        </div>
      </div>

      <!-- Input 2: Active Nodes -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="nodes-slider" class="text-neutral-700 dark:text-neutral-300">Active Linux VPS Compute Nodes</label>
          <span id="nodes-value" class="text-primary font-mono text-base">3</span>
        </div>
        <input 
          type="range" 
          id="nodes-slider" 
          min="1" 
          max="10" 
          step="1" 
          value="3" 
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>1 Core VPS</span>
          <span>10 Hardened Nodes</span>
        </div>
      </div>

      <!-- Input 3: Payload Size -->
      <div class="space-y-2">
        <div class="flex justify-between items-center text-sm font-semibold">
          <label for="payload-slider" class="text-neutral-700 dark:text-neutral-300">Inbound Photo Payload Image Size</label>
          <span id="payload-value" class="text-primary font-mono text-base">128 KB</span>
        </div>
        <input 
          type="range" 
          id="payload-slider" 
          min="32" 
          max="1024" 
          step="32" 
          value="128" 
          class="w-full h-2 bg-neutral-200 dark:bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-primary"
        />
        <div class="flex justify-between text-xs text-neutral-400 font-mono">
          <span>32 KB (Text)</span>
          <span>1,024 KB (High-Res Image)</span>
        </div>
      </div>
    </div>

    <!-- Technical Info footer -->
    <div class="border-t border-neutral-100 dark:border-neutral-800 pt-4 text-xs text-neutral-400 flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Decoupled API gateway simulator with adaptive queue calculations.</span>
    </div>
  </div>

  <!-- Telemetry Dashboard (Outputs) -->
  <div class="flex-1 flex flex-col justify-between p-6 rounded-xl bg-neutral-50 dark:bg-neutral-950 border border-neutral-150 dark:border-neutral-850">
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider text-neutral-400 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse" id="status-dot"></span>
        Telemetry Readout
      </h3>
    </div>

    <!-- Outputs display -->
    <div class="my-auto py-6 space-y-8">
      <!-- Readout 1: Stability Status -->
      <div class="text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">System Stability</span>
        <div id="stability-status" class="mt-2 text-2xl font-black uppercase tracking-wide text-emerald-500 transition-all duration-300">
          Stable
        </div>
      </div>

      <!-- Readout 2: CPU Utilization -->
      <div class="space-y-2">
        <div class="flex justify-between text-xs font-semibold text-neutral-500 dark:text-neutral-400">
          <span>Total CPU Utilization</span>
          <span id="cpu-value" class="font-mono text-sm text-neutral-800 dark:text-neutral-200">40%</span>
        </div>
        <div class="w-full bg-neutral-200 dark:bg-neutral-700 rounded-full h-3 overflow-hidden">
          <div id="cpu-progress" class="bg-emerald-500 h-full rounded-full transition-all duration-300" style="width: 40%;"></div>
        </div>
      </div>

      <!-- Readout 3: Pipeline Latency -->
      <div class="space-y-1 text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Projected Pipeline Latency</span>
        <div class="flex items-baseline justify-center gap-1 mt-1">
          <span id="latency-value" class="text-4xl font-extrabold text-neutral-950 dark:text-white font-mono tracking-tight transition-all duration-300">
            72
          </span>
          <span class="text-neutral-400 text-lg font-medium">ms</span>
        </div>
      </div>
    </div>

    <!-- Node cluster map visualization -->
    <div class="border-t border-neutral-200/50 dark:border-neutral-800/50 pt-4">
      <div class="text-xs font-semibold text-neutral-400 mb-2">Node Cluster State</div>
      <div class="flex flex-wrap gap-2" id="node-grid">
        <!-- Node badges will be dynamically generated by JS -->
      </div>
    </div>
  </div>
</div>

<script>
  function initSimulator() {
    const scansSlider = document.getElementById('scans-slider') as HTMLInputElement;
    const nodesSlider = document.getElementById('nodes-slider') as HTMLInputElement;
    const payloadSlider = document.getElementById('payload-slider') as HTMLInputElement;

    const scansValue = document.getElementById('scans-value');
    const nodesValue = document.getElementById('nodes-value');
    const payloadValue = document.getElementById('payload-value');

    const stabilityStatus = document.getElementById('stability-status');
    const statusDot = document.getElementById('status-dot');
    const cpuValue = document.getElementById('cpu-value');
    const cpuProgress = document.getElementById('cpu-progress');
    const latencyValue = document.getElementById('latency-value');
    const nodeGrid = document.getElementById('node-grid');

    if (!scansSlider || !nodesSlider || !payloadSlider) return;

    function updateTelemetry() {
      const scans = parseInt(scansSlider.value);
      const nodes = parseInt(nodesSlider.value);
      const payload = parseInt(payloadSlider.value);

      // 1. Format slider readouts
      if (scansValue) scansValue.textContent = scans.toLocaleString();
      if (nodesValue) nodesValue.textContent = nodes.toString() + (nodes === 1 ? ' Core' : ' Nodes');
      if (payloadValue) payloadValue.textContent = payload.toLocaleString() + ' KB';

      // 2. Calculations
      // CPU Utilization calculation
      // base CPU is 5%, + load factor.
      // S: scans (1000 - 25000)
      // P: payload size (32 - 1024)
      // N: nodes (1 - 10)
      const S_ratio = scans / 5000;
      const P_ratio = payload / 128;
      const N_ratio = 3 / nodes;
      
      let cpu = Math.round(5 + 35 * S_ratio * P_ratio * N_ratio);
      cpu = Math.max(5, Math.min(100, cpu));

      // Latency calculation
      // base latency determined by payload size (network transit & parsing time)
      const baseLatency = 40 + payload / 4; 
      // queueing delay if CPU is high
      let queueDelay = 0;
      if (cpu > 70) {
        queueDelay = Math.pow((cpu - 70) / 30, 2) * 450;
      }
      // distributed node efficiency (more nodes scale processing capacity)
      const nodeFactor = 1.2 - 0.2 * (nodes / 3);
      let latency = Math.round(baseLatency * nodeFactor + queueDelay);
      latency = Math.max(20, Math.min(2000, latency));

      // 3. Update Status and Classes
      let status = 'Stable';
      let statusColor = 'text-emerald-500';
      let dotColor = 'bg-emerald-500';
      let progressColorClass = 'bg-emerald-500';

      if (cpu >= 90) {
        status = 'Overloaded';
        statusColor = 'text-red-500 font-extrabold animate-pulse';
        dotColor = 'bg-red-500';
        progressColorClass = 'bg-red-500';
      } else if (cpu >= 70) {
        status = 'Warning';
        statusColor = 'text-amber-500 font-bold';
        dotColor = 'bg-amber-500';
        progressColorClass = 'bg-amber-500';
      }

      // Update UI readouts
      if (stabilityStatus) {
        stabilityStatus.textContent = status;
        stabilityStatus.className = `mt-2 text-2xl font-black uppercase tracking-wide ${statusColor} transition-all duration-300`;
      }

      if (statusDot) {
        statusDot.className = `w-2.5 h-2.5 rounded-full ${dotColor} ${status === 'Overloaded' ? 'animate-ping' : status === 'Warning' ? 'animate-pulse' : ''}`;
      }

      if (cpuValue) cpuValue.textContent = `${cpu}%`;
      
      if (cpuProgress) {
        cpuProgress.style.width = `${cpu}%`;
        cpuProgress.className = `h-full rounded-full transition-all duration-300 ${progressColorClass}`;
      }

      if (latencyValue) {
        latencyValue.textContent = latency.toString();
        // Shift latency text color depending on performance thresholds
        if (latency > 300) {
          latencyValue.className = 'text-4xl font-extrabold text-red-500 dark:text-red-400 font-mono tracking-tight transition-all duration-300';
        } else if (latency > 150) {
          latencyValue.className = 'text-4xl font-extrabold text-amber-500 dark:text-amber-400 font-mono tracking-tight transition-all duration-300';
        } else {
          latencyValue.className = 'text-4xl font-extrabold text-neutral-950 dark:text-white font-mono tracking-tight transition-all duration-300';
        }
      }

      // 4. Update Node Cluster Visualizer
      if (nodeGrid) {
        nodeGrid.innerHTML = '';
        for (let i = 1; i <= nodes; i++) {
          const nodeBadge = document.createElement('div');
          
          let nodeStatus = 'Active';
          let bgClass = 'bg-emerald-500/10 text-emerald-800 dark:text-emerald-400 border-emerald-500/30';
          
          if (cpu >= 90) {
            nodeStatus = 'Critical';
            bgClass = 'bg-red-500/10 text-red-800 dark:text-red-400 border-red-500/30';
          } else if (cpu >= 70) {
            nodeStatus = 'Heavy';
            bgClass = 'bg-amber-500/10 text-amber-800 dark:text-amber-400 border-amber-500/30';
          }

          nodeBadge.className = `text-[10px] font-mono font-semibold px-2 py-1 rounded border flex items-center gap-1 ${bgClass}`;
          nodeBadge.innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${cpu >= 90 ? 'bg-red-500 animate-pulse' : cpu >= 70 ? 'bg-amber-500' : 'bg-emerald-500'}"></span>Node ${i}: ${nodeStatus}`;
          nodeGrid.appendChild(nodeBadge);
        }
      }
    }

    // Set event listeners
    scansSlider.addEventListener('input', updateTelemetry);
    nodesSlider.addEventListener('input', updateTelemetry);
    payloadSlider.addEventListener('input', updateTelemetry);

    // Initial run
    updateTelemetry();
  }

  // Setup execution on load and page transition
  document.addEventListener('DOMContentLoaded', initSimulator);
  // Supporting Astro view transitions if used
  document.addEventListener('astro:page-load', initSimulator);
</script>
