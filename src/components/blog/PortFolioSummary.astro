---
import PortFolio from '~/components/widgets/PortFolio.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
---

<!-- SECTION 3: CASE STUDIES (The Proof) -->
<PortFolio
  id="portfolio"
  title="Sovereign Implementations & Local Case Studies"
  tagline="Proven Technical Deployment"
  classes={{
    panel: 'bg-blue-950 text-white',
    container: 'pt-12 pb-4 md:pt-16 md:pb-4 lg:pt-20 lg:pb-4',
    action: 'text-primary dark:text-accent',
  }}
  items={[
    {
      title: 'Custom Corporate Web Systems',
      icon: 'carbon:application-web',
      description:
        'Engineered a highly tailored regional web property following Ford’s global corporate layout system constraints, resulting in a flawless localized frontend interface for regional customers.',
    },
  ]}
  image={{
    src: '~/assets/images/ford_raptor.webp',
    alt: "Ford's website design sarawak - custom corporate web system engineered for local user metrics",
  }}
  callToAction={{
    text: 'Analyze Architecture Case Story',
    icon: 'tabler:chevron-right',
    href: '/clients/ford-web-design/',
  }}
>
  <Fragment slot="content">
    <h3 class="text-xl font-bold tracking-tight dark:text-white sm:text-2xl mb-2">
      Corporate Web Design for Ford Standards <br /><span class="text-lg font-semibold text-neutral-400"
        >UI/UX Tailored for Regional Demographics</span
      >
    </h3>
  </Fragment>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</PortFolio>

<PortFolio
  isReversed
  isAfterContent
  classes={{
    panel: 'bg-amber-300 dark:bg-fuchsia-950',
    container: 'py-4 md:py-4 lg:py-4',
    action: 'text-secondary dark:text-accent',
  }}
  items={[
    {
      title: 'Conversion Engine Modernization',
      icon: 'carbon:application-web',
      description:
        'Optimized inbound customer capture paths for Bos Office System by engineering targeted algorithmic ad integration layers, maximizing customer request acquisition times.',
    },
  ]}
  image={{
    src: '~/assets/images/bosoffice_chair.webp',
    alt: 'Automated digital acquisition deployment for Bos Office System',
  }}
  callToAction={{
    text: 'View Acquisition Framework',
    icon: 'tabler:chevron-right',
    href: '/clients/bosoffice/',
  }}
>
  <Fragment slot="content">
    <h3 class="text-xl font-bold tracking-tight dark:text-white sm:text-2xl mb-2">
      Bos Office System Integration <br /><span class="text-lg font-semibold dark:text-neutral-300"
        >Algorithmic Traffic Routing & Capture</span
      >
    </h3>
  </Fragment>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</PortFolio>

<PortFolio
  isAfterContent
  classes={{
    panel: 'bg-[#e1e1e1] dark:bg-slate-700',
    container: 'py-4 md:py-4 lg:py-4',
    action: 'text-secondary dark:text-accent',
  }}
  items={[
    {
      title: 'Native Hardware Layer Bluetooth Beacons',
      icon: 'carbon:application-web',
      description:
        'Architected a highly secure, non-line-of-sight Bluetooth Low Energy (BLE) beacon tracking array to bypass traditional QR entry limits, providing real-time data persistence under extreme field conditions.',
    },
  ]}
  image={{
    src: '~/assets/images/wristband2.webp',
    alt: 'Custom app development of native bluetooth telemetry tracking arrays for infrastructure deployment in Sarawak',
  }}
  callToAction={{
    text: 'Examine Hardware Logic',
    icon: 'tabler:chevron-right',
    href: '/clients/digital-border-control/',
  }}
>
  <Fragment slot="content">
    <h3 class="text-xl font-bold tracking-tight dark:text-white sm:text-2xl mb-2">
      Infrastructure Border Control System <br /><span
        class="text-lg font-semibold text-neutral-600 dark:text-neutral-300"
        >Native Hardware BLE Beacons vs Static QR Codes</span
      >
    </h3>
  </Fragment>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</PortFolio>

<CallToAction
  classes={{ container: 'pt-2 pb-12 md:pb-16 lg:pb-20' }}
  actions={[
    {
      variant: 'secondary',
      text: 'Review Complete Technical Case Index',
      href: '/clients/',
    },
  ]}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-page"></div>
  </Fragment>
</CallToAction>
