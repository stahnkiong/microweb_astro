---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero3 from '~/components/widgets/Hero3.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Steps4 from '~/components/widgets/Steps4.astro';
import Layout from '~/layouts/PageLayout.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import PortFolioSummary from '~/components/blog/PortFolioSummary.astro';
import PortFolio from '~/components/widgets/PortFolio.astro';

const metadata = {
  title: 'Systems Architects & Custom Software Engineers | MicroWeb',
  description:
    'Rooted in Kuching since 2012. We engineer network-resilient custom applications, edge-cached web platforms, and zero-management WhatsApp-to-ERP integration pipelines across Malaysia.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero3>
    <Fragment slot="title">
      Engineering Performance-Driven <br />
      <span class="text-accent dark:text-white highlight">Custom Software & Integrations</span>
    </Fragment>

    <Fragment slot="subtitle">
      At MicroWeb, we don't build temporary marketing landers; we architect permanent digital infrastructure. We
      specialize in isolating high-friction operational bottlenecks and deploying decoupled, edge-managed systems that
      eliminate manual key-in debt and mitigate enterprise tech-shock.
    </Fragment>
  </Hero3>
  <Banners2 isBgBlack="true" />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Our Core Architecture Maxims"
    subtitle="We discard bloated administrative overhead and theoretical perfection. We deliver predictable backend stability using strict software engineering protocols."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Velocity Over Elegance',
        description:
          'We build lean, highly targeted Minimum Viable Products (MVPs) to isolate and eliminate workflow failures in production quickly, avoiding the high cost of premature optimization.',
        icon: 'carbon:gears',
      },
      {
        title: 'Friction-Free Interface Decoupling',
        description:
          'We protect users from technology adoption failure by wrapping advanced logic inside existing daily habits—such as using automated WhatsApp pipelines to process structural data from photos.',
        icon: 'carbon:cloud',
      },
      {
        title: 'Digital Sovereignty & Security',
        description:
          'We secure regional data assets behind enterprise Cloudflare Edge Shield arrays, ensuring low latency and consistent compliance with local data hosting parameters.',
        icon: 'carbon:security',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    image={{
      src: '~/assets/images/aboutus.jpg',
      alt: 'MicroWeb custom application developers blueprinting software infrastructure solutions in Kuching, Sarawak',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Engineering Execution Blueprint"
    subtitle="<p>Software durability relies entirely on backend predictability. Our agency is organized around clean dependency isolation and iterative delivery to maximize structural lifespan.</p><p class='mt-4'>By treating volatile networks and shifting corporate parameters as constants during the design phase, we build software environments that easily withstand a decade of technology lifecycle shifts.</p>"
    items={[
      {
        title: 'Component-Isolated Specialists',
        description:
          'Our systems engineers focus exclusively on independent modules, ensuring clean separation of concerns and dropping layout or database serialization friction to absolute zero.',
      },
      {
        title: 'Decoupled API Agility',
        description:
          'Because our backends rely on modular content schemas and isolated API wrappers, resources can be scaled up or reassigned instantly without endangering the core database state.',
      },
      {
        title: 'Automated CI/CD Delivery',
        description:
          'Every incremental patch or integration update runs through automated verification testing via GitHub Actions, completely preventing configuration drift across hosting environments.',
      },
    ]}
  />

  <PortFolio
    id="porfolio"
    title="Our Innovation Pipeline"
    tagline="Active R&D Focus"
    classes={{
      panel: 'bg-neutral-100 dark:bg-neutral-600 border border-black dark:border-0',
      container: 'pb-4 pt-12 md:pb-8 md:pt-4 lg:pb-8 lg:pt-4',
      action: 'text-secondary dark:text-accent',
    }}
    items={[
      {
        title: 'Client-Side Real-Time 3D Simulation Engines',
        icon: 'carbon:application-web',
        description:
          'Architecting open-source, WebGL-driven educational frameworks that run interactive deterministic physics models completely in-browser, bypassing heavy local hardware configurations.',
      },
    ]}
    image={{
      src: '~/assets/images/blog/kidsthinking.webp',
      alt: 'Open-source 3D physics engine and interactive learning platform architecture by MicroWeb',
    }}
    callToAction={{
      text: 'Review Engine Breakdown',
      icon: 'tabler:chevron-right',
      href: '/clients/3d-learning-platform',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-xl font-bold tracking-tight dark:text-white sm:text-2xl mb-2">
        Re-Engineering Digital Instruction <br /><span class="text-lg font-semibold"
          >Replacing Passive Consumption with Multi-Variable Simulation Environment</span
        >
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-page"></div>
    </Fragment>
  </PortFolio>

  <Features4
    tagline="Core Architecture Vector"
    title="Specialized Systems Engineered for Transactional Scale"
    columns={4}
    classes={{ container: 'my-24 md:mb-0 md:pb-20' }}
    items={[
      {
        title: 'Custom App Development',
        description: 'Secure, high-availability mobile & web application architectures tailored for regional scale.',
        link: '/software',
        icon: 'carbon:network-enterprise',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Enterprise System Integration',
        description: 'Bridging legacy core databases with modern API pipelines and decoupled third-party web services.',
        link: '/integration',
        icon: 'carbon:ibm-z-cloud-mod-stack',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'WhatsApp Automation Pipelines',
        description: 'Eliminate manual data key-in errors using low-latency computer-vision photo processing models.',
        link: '/ai-marketing',
        icon: 'carbon:machine-learning-model',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'High-Performance Web Design',
        description: 'Edge-cached corporate properties optimized for high Core Web Vitals and local organic authority.',
        link: '/web-development',
        icon: 'carbon:dashboard',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
    ]}
  />

  <Steps4
    title="Our Engineering Timeline"
    subtitle="A 14-Year Trajectory of Infrastructure Delivery"
    items={[
      {
        title: '2012',
        description:
          'Established local software development core in Sarawak, building data-optimized web applications for local business sectors.',
        icon: 'carbon:devices',
      },
      {
        title: '2013',
        description:
          'Deployed enterprise corporate architecture for Sri Datai Holdings using Drupal 7, a system that continues running flawlessly today.',
        icon: 'carbon:building-insights-2',
      },
      {
        title: '2014',
        description:
          'Scaled into regional B2B e-commerce infrastructure, deploying high-volume transactional catalogs and inventory layers for corporate groups.',
        icon: 'carbon:shopping-cart-plus',
      },
      {
        title: '2016',
        description:
          'Expanded capabilities to include custom native mobile applications, optimizing performance states across iOS and Android runtime platforms.',
        icon: 'carbon:application-mobile',
      },
      {
        title: '2020',
        description:
          'Engineered a mission-critical automated BLE beacon tracking grid and telemetry integration layer for high-security regional border control.',
        icon: 'carbon:security',
      },
      {
        title: '2021',
        description:
          'Architected and deployed a cloud-managed, network-resilient Raspberry Pi IoT digital display fleet across retail endpoints for Adidas East Malaysia.',
        icon: 'carbon:iot-platform',
      },
      {
        title: '2025',
        description:
          'Managed the high-availability DevOps architecture for #SCEKL25, delivering zero-downtime, sub-second latency access for 21,895 international attendees.',
        icon: 'carbon:earth-southeast-asia',
      },
      {
        title: '2026',
        description:
          'Launched Omnia Foods B2B supply chain core on MedusaJS & Docker alongside our proprietary zero-habit-change WhatsApp photo integration pipeline.',
        icon: 'carbon:gears',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps4>

  <PortFolioSummary />

  <Features2
    title="Our Structural Regions"
    tagline="Operational Coordinates"
    columns={2}
    items={[
      {
        title: 'Kuching (HQ)',
        description: 'Pending Industrial Estate, 93450 Kuching, Sarawak, Malaysia',
      },
      {
        title: 'Kuala Lumpur',
        description: 'Arcoris Mont Kiara, 50480 Kuala Lumpur, Malaysia',
      },
    ]}
  />
</Layout>
