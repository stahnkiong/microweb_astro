---
import Layout from '~/layouts/PageLayout.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';
import Hero from '~/components/widgets/Hero.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
---

<Layout>
  <ThreeJs />
  <!-- Hero Widget ******************* -->
  <Hero tagline="App Developer & Enterprise System Integration Company in Kuching, Sarawak">
    <Fragment slot="title">
      <span class="text-primary text-gradient highlight">Deploy Your Next </span>Top Performer:<br />An Invisible
      Automation Shield
    </Fragment>
    <Fragment slot="subtitle">
      Stop fighting user adoption friction or complex forms. As a leading app company in Kuching, we engineer
      high-performance custom software and automated WhatsApp integrations that let clients submit orders, track stock,
      and process documents via a single photo 24/7.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 grid grid-cols-2 -space-x-52">
        <div class="blur-[106px] h-64 bg-gradient-to-br from-red-100 to-sky-300 md:to-purple-100 dark:from-blue-700">
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-100 to-red-400 md:to-violet-400 dark:to-indigo-600">
        </div>
      </div>
    </Fragment>
  </Hero>

  <Features4
    columns={4}
    classes={{ container: 'mb-96 md:mb-0 md:pb-20' }}
    items={[
      {
        title: 'Custom App Development',
        description: 'Secure, high-availability mobile & web application architectures tailored for regional scale.',
        link: '/software',
        icon: 'carbon:network-enterprise',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Enterprise System Integration',
        description: 'Bridging legacy databases with modern API pipelines and decoupled third-party ecosystems.',
        link: '/integration',
        icon: 'carbon:ibm-z-cloud-mod-stack',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'WhatsApp Agents & Automation',
        description: 'Eliminate manual key-in friction using computer-vision pipelines running natively inside chat.',
        link: '/ai-marketing',
        icon: 'carbon:machine-learning-model',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'High-Performance Web Design',
        description:
          'Edge-cached, fast-loading corporate properties optimized for local search authority and core web vitals.',
        link: '/web-development',
        icon: 'carbon:dashboard',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
    ]}
  />

  <Banners2 />
  <FollowUp />

  <Steps3
    image={{
      src: '~/assets/images/process.webp',
      alt: 'MicroWeb systems engineers blueprinting a custom integration schema',
    }}
    title="Velocity Over Elegance: Our Development Lifecycle"
    subtitle="<strong>Start small, validate fast, scale permanently.</strong> We decouple complex dependencies to isolate and eliminate operational bottlenecks within weeks, not months."
    items={[
      {
        title: '1. <span class="font-medium">Deconstruct Bottlenecks</span>',
        description:
          'We audit your current operational workflows to target the single highest-friction administrative point.',
        icon: 'carbon:forum',
      },
      {
        title: '2. <span class="font-medium">Isolate the MVP Core</span>',
        description:
          'We wire up a thin prototype interface to validate core data flow paths using real production variables.',
        icon: 'carbon:devices',
      },
      {
        title: '3. <span class="font-medium">Automated Engineering</span>',
        description:
          'We build out stable module backends paired with automated continuous testing pipelines to prevent technical debt.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: '4. <span class="font-medium">Edge Deployment</span>',
        description:
          'We launch across secure container environments, hardwiring a Cloudflare protection perimeter for local digital sovereignty.',
        icon: 'carbon:cloud-data-ops',
      },
      {
        title: '5. <span class="font-medium">Lifecycle Monitoring</span>',
        description:
          'We deploy persistent monitoring telemetry tools to handle routine exceptions and track data optimization velocities.',
        icon: 'carbon:cloud-monitoring',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>
</Layout>
