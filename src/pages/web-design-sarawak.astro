---
// src/pages/web-design-sarawak.astro
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features5 from '~/components/widgets/Features5.astro';
import ContentContact from '~/components/widgets/ContentContact.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import LatencySimulator from '~/components/widgets/LatencySimulator.astro';

// Global Metadata targeting cross-border enterprise expansion searches
const metadata = {
  ignoreTitleTemplate: true,
  title: 'Web Design Sarawak | Cross-Border Regional System Custom Software | MicroWeb',
  description:
    'Localized web design and web development infrastructure in Sarawak for West Malaysian and global brands. We engineer high-availability edge systems designed to eliminate cross-region latency.',
};
---

<Layout metadata={metadata}>
  <ThreeJs />

  <!-- SECTION 1: REGIONAL ENTRY HERO -->
  <Hero2
    tagline="Sarawak Market Expansion Engineering"
    actions={[
      { variant: 'primary', text: 'Request Regional Expansion Strategy', href: '#contact' },
      {
        variant: 'secondary',
        text: 'Connect with Systems Architect',
        target: '_blank',
        href: 'https://wa.me/60168880650',
      },
    ]}
    image={{
      src: '~/assets/images/web_design_development_kuching.webp',
      alt: 'Decoupled web application architectures syncing cross-region databases between Peninsular Malaysia and Sarawak edge routing points',
    }}
  >
    <Fragment slot="title">
      Web Design Sarawak: <span class="text-primary text-gradient highlight tracking-tight"
        >Localize Your Digital Asset</span
      > Without System Shock
    </Fragment>

    <Fragment slot="subtitle">
      We help West Malaysian corporations and international brands deploy high-performance, Sarawak-optimized web
      applications. From eliminating South China Sea data routing latencies to embedding localized regional search
      indexing arrays, we ensure your expansion matches local infrastructure realities.
    </Fragment>

    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Cross-Region<br/>SEO Replication',
            icon: 'carbon:language',
          },
          {
            description: 'South China Sea<br/>Latency Mitigation',
            icon: 'carbon:cloud-service-management',
          },
          {
            description: 'Linguistic & Cultural<br/>Localization Filters',
            icon: 'carbon:group-account',
          },
          {
            description: 'Decoupled Multi-Channel<br/>Database Sync',
            icon: 'carbon:translate',
          },
        ]}
      />
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-500 md:to-purple-300 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-300 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>

  <Banners2 />

  <!-- SECTION 2: INTERACTIVE NETWORK LATENCY & CACHE SIMULATOR -->
  <section class="max-w-5xl mx-auto px-6 py-12 not-prose">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-black tracking-tight text-neutral-900 dark:text-white">
        South China Sea Latency & Data Performance Simulator
      </h2>
      <p class="text-neutral-500 dark:text-neutral-400 mt-2 max-w-2xl mx-auto text-sm">
        Hosting your applications solely on a Peninsular Malaysia (KL) origin server introduces significant data routing
        delay for East Malaysian users. Simulate how adding localized edge caching configurations saves transaction
        speed.
      </p>
    </div>

    <LatencySimulator height="600px" />
  </section>

  <!-- SECTION 3: SYMMETRIC CROSS-BORDER PARAMETERS MATRIX -->
  <Features2
    id="why-global"
    tagline="Ecosystem Interconnection"
    title="Your Localized Engineering Extension in East Malaysia"
    subtitle="We unify strict international design system blueprints with local network configurations to prevent user drop-offs."
    columns={3}
    items={[
      {
        title: 'Localized Search Engine Authority',
        description:
          'We injection specific geolocation schema properties and structured cross-region indexing nodes, ensuring your corporate web footprint dominates search targets like web development sarawak natively.',
        icon: 'carbon:search-advanced',
      },
      {
        title: 'Hybrid Edge Cloud Host Layouts',
        description:
          'By distributing static site assets and operational components to serverless nodes within the region, we isolate your application loops from mainland routing infrastructure vulnerabilities.',
        icon: 'carbon:data-center',
      },
      {
        title: 'Linguistic Demographic Targeting',
        description:
          "We structure content workflows tailored for East Malaysia's distinct multicultural commerce base, allowing deep alignment across targeted regional business sub-demographics.",
        icon: 'carbon:user-certification',
      },
      {
        title: 'Decoupled Headless Content Sync',
        description:
          'We link your existing centralized ERP or global web content structures straight into lightweight localized viewports via non-blocking API queue pipelines.',
        icon: 'carbon:cics-system-group',
      },
      {
        title: 'Compliance & Governance Assured',
        description:
          'Every architecture blueprint we compile adheres strictly to statutory regulatory frameworks, ensuring persistent corporate protection and data privacy safety.',
        icon: 'carbon:security',
      },
      {
        title: 'KL-to-Kuching Developer Coordination',
        description:
          'We act as your remote technical staff on the ground. We execute rapid continuous updates and monitor local telemetry logs without operational management friction.',
        icon: 'carbon:collaborate',
      },
    ]}
  />

  <!-- SECTION 4: STRATEGIC REGIONAL MATCH SECTORS -->
  <section
    class="bg-neutral-50 dark:bg-neutral-900/30 py-16 not-prose border-t border-b border-neutral-200/50 dark:border-neutral-800/50"
  >
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center text-neutral-900 dark:text-white mb-10">
        Engineered Solutions for Expanding System Footprints
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div
          class="bg-white dark:bg-neutral-900 p-6 rounded-xl border border-neutral-200 dark:border-neutral-800 space-y-3"
        >
          <h3 class="text-lg font-bold text-primary flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-primary"></span>
            Peninsular Malaysian Enterprises
          </h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
            Protect your brand investments. We map multi-location website delivery paths, coordinate content
            synchronization schedules between your HQ servers and local targets, and build optimized landing networks to
            lower your customer acquisition costs across the region.
          </p>
        </div>
        <div
          class="bg-white dark:bg-neutral-900 p-6 rounded-xl border border-neutral-200 dark:border-neutral-800 space-y-3"
        >
          <h3 class="text-lg font-bold text-accent flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent"></span>
            Multinational & International Brands
          </h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
            Ensure your global platform complies with regional technical realities. We adapt your enterprise design
            tokens for sub-second mobile delivery, configure multilingual customer pathways, and integrate localized
            transaction nodes straight into your global tech stack.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: CROSS-BORDER INTEGRATION PIPELINE -->
  <Steps3
    image={{
      src: '~/assets/images/webdev.webp',
      alt: 'Enterprise technical directors monitoring cross-region network telemetry states and database synchronization pipelines',
    }}
    title="The Global-to-Local Deployment Pipeline"
    subtitle="A structured technical transition roadmap configured to maximize conversion velocities across geographic borders safely."
    items={[
      {
        title: '1. Regional Infrastructure Valuation',
        description:
          'We audit your global design configurations against local consumer network parameters to isolate performance bottlenecks.',
        icon: 'carbon:earth-southeast-asia-filled',
      },
      {
        title: '2. Linguistic & Content Optimization',
        description:
          'We align landing directory copy blocks with localized regional vocabulary patterns to maximize search engine authority.',
        icon: 'carbon:group-account',
      },
      {
        title: '3. Abstraction API Engineering',
        description:
          'Our team developments secure communication middleware bridges to connect edge user actions straight to your primary core databases.',
        icon: 'carbon:integration',
      },
      {
        title: '4. Localized SEO Cluster Rollout',
        description:
          'We hardwire structural geographic indicators, schema properties, and site maps into the static runtime targets natively.',
        icon: 'carbon:location-filled',
      },
      {
        title: '5. South China Sea Stress Verifications',
        description:
          'We validate data processing latencies and transaction consistency across real-world regional network carrier profiles.',
        icon: 'carbon:meter',
      },
      {
        title: '6. Boundary Protection & Staging',
        description:
          'We deploy your localized application frontends safely behind an active edge firewall shield, managing patches automatically.',
        icon: 'carbon:customer-service',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <!-- SECTION 6: ENTERPRISE EXPANSION INTAKE GATEWAY -->
  <ContentContact id="contact">
    <Fragment slot="content">
      <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl">
        Initiate a Regional Scoping Consultation
      </h2>
      <p class="mt-2 md:mt-4 text-lg font-semibold text-primary dark:text-accent">
        Secure your regional transaction speeds and eliminate cross-border technical debt.
      </p>
      <p class="mt-2 md:mt-4 text-neutral-600 dark:text-neutral-400">
        Stop serving slow, centralized web resources that lag over regional marine routing links. We engineer
        high-availability, decoupled frontend architectures, secure cross-region API bridges, and localized optimization
        frameworks programmed to align your centralized system logic natively with local market demands.<br />
        <strong
          >Let's execute — Contact our system architect team today to map out your localized digital assets.</strong
        >
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-white/40 dark:bg-neutral-950/20"></div>
    </Fragment>
  </ContentContact>
</Layout>
