---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';

const metadata = {
  ignoreTitleTemplate: true,
  title: 'Custom Software & Web Application Development | MicroWeb',
  description:
    "Sarawak's premier custom app developer company. We engineer high-availability web applications, secure API architectures, and zero-management automation backends for enterprises across Malaysia.",
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero2
    tagline="Custom Software & Web Application Development"
    actions={[{ variant: 'primary', text: 'Request Architectural Proposal', href: '#contact' }]}
    image={{
      src: '~/assets/images/custom_web_application_developement.webp',
      alt: 'Dashboard showcasing secure web application performance and API telemetry analytics',
    }}
  >
    <Fragment slot="title">
      High-Availability <span class="text-primary text-gradient highlight tracking-tight">Custom Software</span> & Web Applications
    </Fragment>

    <Fragment slot="subtitle">
      We engineer high-performance, secure web applications designed to decouple technical debt and eliminate manual
      workflow bottlenecks. From regional B2B logistics nodes to custom cloud layouts, we build software that adapts
      seamlessly to your operational scale.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Decoupled<br/>Architectures',
            icon: 'carbon:cloud-service-management',
          },
          {
            description: 'High-Availability<br/>Uptime',
            icon: 'carbon:security',
          },
          {
            description: 'Automated Data<br/>Pipelines',
            icon: 'carbon:archive',
          },
          {
            description: 'Legacy System<br/>Integrations',
            icon: 'carbon:app-connectivity',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-500 md:to-purple-300 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-300 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>

  <Banners2 />

  <Features4
    id="features"
    tagline="Enterprise Sector Architectures"
    columns={3}
    title="Custom Application Engineering Across Key Sectors"
    subtitle="We provide compliance-ready, highly maintainable technology stacks optimized for regional transaction velocities."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'B2B Supply Chain & Logistics',
        description: 'Decoupled headless marketplace platforms and secure tracking ledger pipelines.',
        link: '/clients/architecting-persistent-b2b-supply-chain-medusajs-docker',
        icon: 'carbon:delivery-truck',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Government & State GLCs',
        description: 'Secure, high-availability digital portals and automated site log verification engines.',
        link: '/clients/behind-scekl25',
        icon: 'carbon:building-insights-3',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Smart Retail & Edge IoT',
        description: 'Network-resilient edge appliance software and centralized device fleet management.',
        link: '/clients/adidas-smart-retail',
        icon: 'carbon:shopping-cart-arrow-down',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'High-Volume E-Commerce',
        description: 'Conversion-rate optimized product architectures built for sub-second page delivery.',
        link: '/clients/bosoffice',
        icon: 'carbon:network-enterprise',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Automated Telemetry Networks',
        description: 'Continuous hardware-to-cloud integration grids utilizing BLE beacon validation protocols.',
        link: '/clients/bluetooth-beacon-border-control',
        icon: 'carbon:industry',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Interactive WebGL Engines',
        description: 'Open-source 3D client-side rendering engines running real-time physics simulations.',
        link: '/clients/3d-learning-platform',
        icon: 'carbon:agriculture-analytics',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/process.webp',
      alt: 'MicroWeb application developers organizing system dependencies on an agile board',
    }}
    title="Velocity Over Elegance: Our Engineering Lifecycle"
    subtitle="We minimize technical debt by starting with focused functional targets, allowing systems to scale cleanly alongside verification metrics."
    items={[
      {
        title: '1. Deconstruct Bottlenecks',
        description:
          'We audit active system workflows to identify the specific operational failure points stalling productivity.',
        icon: 'carbon:forum',
      },
      {
        title: '2. Isolate the MVP Core',
        description:
          'We prototype a thin, high-velocity functional interface to validate underlying data schema paths in production.',
        icon: 'carbon:devices',
      },
      {
        title: '3. Automated Development',
        description:
          'We write robust application code backed by rigorous continuous testing blocks to isolate external dependencies.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: '4. Edge Infrastructure Rollout',
        description:
          'We deploy containerized application blocks, hardwiring an enterprise Cloudflare perimeter for regional data sovereignty.',
        icon: 'carbon:cloud-data-ops',
      },
      {
        title: '5. Automated Telemetry',
        description:
          'We monitor continuous runtime telemetry to track packet execution speeds and neutralize drift before exceptions occur.',
        icon: 'carbon:cloud-monitoring',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
