---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';
const metadata = {
  ignoreTitleTemplate: true,
  title: 'Mission-Critical Software & Digital Infrastructure Partner',
  description:
    "Sarawak's trusted partner for Government & Enterprise digital infrastructure. Specializing in PDPA-compliant systems, secure API integration, and sovereign cloud solutions.",
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero2
    tagline="Digital Infrastructure Partner"
    actions={[{ variant: 'primary', text: "Request Technical Proposal", href: '#contact' }]}
    image={{
      src: '~/assets/images/custom_web_application_developement.webp',
      alt: 'Dashboard showing government-grade digital infrastructure metrics',
    }}
  >
    <Fragment slot="title">
      <span class="text-primary text-gradient highlight tracking-tight">Mission-Critical</span> Software Solutions for Sarawak's Future
    </Fragment>

    <Fragment slot="subtitle">
      We engineer <strong>sovereign, scalable, and secure</strong> digital platforms. From PDPA-compliant healthcare systems to automated government workflows, we build the infrastructure that powers Sarawak's digital economy.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Sovereign<br/>Cloud',
            icon: 'carbon:cloud-service-management',
          },
          {
            description: 'Gov-Grade<br/>Security',
            icon: 'carbon:security',
          },
          {
            description: 'IoT Data<br/>Intelligence',
            icon: 'carbon:archive',
          },
          {
            description: 'Legacy<br/>Integration',
            icon: 'carbon:app-connectivity',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-500 md:to-purple-300 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-300 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>

  <Banners2 />

  <Features4
    id="features"
    tagline="Sector-Specific expertise"
    columns={3}
    title="Digital Infrastructure for Key Industries"
    subtitle="We provide compliance-ready technology stacks tailored for Sarawak's core economic sectors."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'Government & GLCs',
        description: 'Secure Data Pipelines & Citizen Portals',
        link: '/enterprise',
        icon: 'carbon:building-insights-3',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Healthcare Systems',
        description: 'PDPA Compliant Patient Management',
        link: '/healthcare',
        icon: 'carbon:hospital-bed',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Smart Logistics',
        description: 'Supply Chain Sovereignty & Tracking',
        link: '/logistics',
        icon: 'carbon:delivery-truck',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Digital Commerce',
        description: 'High-Volume Transaction Processing',
        link: '/retail',
        icon: 'carbon:shopping-cart-arrow-down',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Industry 4.0',
        description: 'Factory Automation & IoT Sensors',
        link: '/manufacturing',
        icon: 'carbon:industry',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'AgriTech Intelligence',
        description: 'Yield Optimization & Soil Analytics',
        link: '/agriculture',
        icon: 'carbon:agriculture-analytics',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Smart Tourism',
        description: 'Visitor Analytics & Booking Systems',
        link: '/hospitality',
        icon: 'carbon:pedestrian-family',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'EdTech Platforms',
        description: 'LMS Integration & Student Data Security',
        link: '/education',
        icon: 'carbon:education',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Immersive Tech',
        description: 'AR/VR Solutions for Training & Sims',
        link: '/games',
        icon: 'carbon:virtual-private-cloud',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/process.webp',
      alt: 'App development team collaborating',
    }}
    title="Our Clear 5-Step Process"
    subtitle="Pay only for what you need now. Start small and scale effortlessly as you grow"
    items={[
      {
        title: '1. Plan & Discover',
        description: 'We define your goals and challenges to build the right solution',
        icon: 'carbon:forum',
      },
      {
        title: '2. Design & Prototype',
        description: 'Create and refine mockups to visualize your perfect solution',
        icon: 'carbon:devices',
      },
      {
        title: '3. Build & Test',
        description: 'Agile development with continuous testing for quality results',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: '4. Launch & Deploy',
        description: 'Seamless rollout to production with full support',
        icon: 'carbon:cloud-data-ops',
      },
      {
        title: '5. Maintain & Grow',
        description: 'Ongoing updates and optimizations to keep you ahead',
        icon: 'carbon:cloud-monitoring',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
