---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';
const metadata = {
  title: 'Mobile App Development',
  ignoreTitleTemplate: true,
  description: 'Mobile App Development, Custom Software Development, Custom Web Application Development',
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero2
    tagline="Citizen-First Mobile Experiences"
    actions={[{ variant: 'primary', text: "Start Citizen Project", href: '#contact' }]}
    image={{
      src: '~/assets/images/web.webp',
      alt: 'Citizen using government mobile service app',
    }}
  >
    <Fragment slot="title">
      Engage, Serve, and <span class="text-primary text-gradient highlight tracking-tight">Protect</span> your Mobile Population
    </Fragment>

    <Fragment slot="subtitle">
      Deploy secure, <strong>offline-first mobile applications</strong> designed for Sarawak's unique geography. Essential for extending government services and enterprise reach to rural communities with limited connectivity.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Offline-First<br/>Architecture',
            icon: 'carbon:no-ticket',
          },
          {
            description: 'Biometric<br/>Security',
            icon: 'carbon:fingerprint-recognition',
          },
          {
            description: 'Population<br/>Scale',
            icon: 'carbon:pricing-consumption',
          },
          {
            description: 'Gov<br/>Compliance',
            icon: 'carbon:bank',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-500 md:to-purple-300 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-300 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>
  <Banners2 />

  <Features4
    id="features"
    tagline="Scalable Mobile Solutions"
    columns={3}
    title="Apps Built for Sovereignty & Scale"
    subtitle="We build mobile infrastructure that withstands high-traffic surges and operates reliably in low-bandwidth environments."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'Citizen-Centric UX',
        description: 'Inclusive design for all demographics (Urban/Rural)',
        icon: 'carbon:user-multiple',
      },
      {
        title: 'Hybrid Deployment',
        description: 'iOS, Android & HarmonyOS ready',
        icon: 'carbon:carbon-for-mobile',
      },
      {
        title: 'Secure Identity',
        description: 'MyKad & SingPass integration ready',
        icon: 'carbon:id-management',
      },
      {
        title: 'Edge Performance',
        description: 'Optimized for instant loading on 4G/5G',
        icon: 'carbon:forecast-lightning',
      },
      {
        title: 'Legacy Bridging',
        description: 'Connects with mainframe agency backends',
        icon: 'carbon:api',
      },
      {
        title: 'Sovereign Data',
        description: 'Local storage compliance guaranteed',
        icon: 'carbon:data-blob',
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/webdev.webp',
      alt: 'Mobile app development team collaborating',
    }}
    title="Our 6-Step App Development Process"
    subtitle="Pay as we build. Get a custom mobile app - no cookie-cutter solutions"
    items={[
      {
        title: '1. Strategy Session',
        description: "We define your app's goals, users, and must-have features",
        icon: 'carbon:forum',
      },
      {
        title: '2. Design & Prototype',
        description: "Create and refine your app's look and feel",
        icon: 'carbon:devices',
      },
      {
        title: '3. Development',
        description: 'We code your app with clean, secure technology',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: '4. Rigorous Testing',
        description: 'Ensure flawless performance on all devices',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: '5. App Store Launch',
        description: 'We handle submission and go-live support',
        icon: 'carbon:cloud-data-ops',
      },
      {
        title: '6. Ongoing Care',
        description: 'Updates, improvements, and maintenance',
        icon: 'carbon:cloud-monitoring',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
