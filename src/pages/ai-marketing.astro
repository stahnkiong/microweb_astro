---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  ignoreTitleTemplate: true,
  title: "Sarawak's First AI-Autonomous Agency",
  description:
    'Software at the Speed of Thought. We use autonomous AI agents to build, test, and self-heal software for Sarawak SMEs, Startups, and Enterprises.',
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero2
    tagline="Software at the Speed of Thought"
    actions={[{ variant: 'primary', text: "Let's Chat", href: '#contact' }]}
    image={{
      src: '~/assets/images/analytics2.png',
      alt: 'AI autonomous agency',
    }}
  >
    <Fragment slot="title">
      Sarawak’s First <span class="text-primary text-gradient highlight tracking-tight">AI-Autonomous Agency</span>
    </Fragment>

    <Fragment slot="subtitle">
      We use Cloud Workstations to run autonomous AI agents that build, test, and self-heal software. Get an entire team
      of full stack developers at an affordable cost—more efficient and accurate than human counterparts.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Autonomous<br/>devs',
            icon: 'carbon:ibm-watsonx-code-assistant',
          },
          {
            description: '24/7<br/>monitoring',
            icon: 'carbon:view-filled',
          },
          {
            description: 'Cost<br/>Efficient',
            icon: 'carbon:money',
          },
          {
            description: 'Accurate<br/>Performance',
            icon: 'carbon:chart-high-low',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-600 md:to-purple-400 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-400 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>
  <Banners2 />

  <Features2
    id="symptoms"
    tagline="Operational Bottlenecks"
    title="Are Immediate Friction Symptoms Costing Your Business Money?"
    subtitle="Identify the operational bottlenecks holding your business back and deploy autonomous systems to resolve them instantly."
    columns={3}
    items={[
      {
        title: 'How to automate customer responses on WhatsApp 24/7',
        description:
          'Leads wait hours for answers and drift to competitors. We build intelligent WhatsApp-native AI agents that qualify, answer FAQs, and engage clients round-the-clock.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Boost local SEO automatically using WhatsApp review loops',
        description:
          'Happy clients forget to leave reviews, causing your search engine and GPT rankings to stagnate. We build automated post-transaction WhatsApp feedback systems that filter for 5-star sentiment and direct satisfied clients straight to your Google Business Profile.',
        icon: 'tabler:seo',
      },
      {
        title: 'Stop missing leads after hours business automation',
        description:
          'Inquiries coming in during nights and weekends are lost forever. Our automation setups instantly capture, qualify, and respond to late-night prospects to hold their attention.',
        icon: 'tabler:clock',
      },
      {
        title: 'How to automatically qualify inbound leads without hiring',
        description:
          'Your team wastes valuable hours manually filtering cold leads. Conversational agents automatically ask target questions (budget, timeline, fit) and pass only hot leads to your sales reps.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Automate appointment booking from website to calendar',
        description:
          'Eliminate endless back-and-forth messaging to schedule a simple call. Our AI integrations sync with Google Calendar or Outlook, letting qualified prospects book meetings instantly.',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'How to handle high volume customer inquiries automatically',
        description:
          'Your customer support is overwhelmed by repetitive questions, slowing resolutions. AI-driven agents handle 80% of routine questions instantly, freeing up your team for high-value tasks.',
        icon: 'tabler:messages',
      },
    ]}
  />

  <Features4
    id="features"
    tagline="Who We Serve"
    columns={3}
    title="Tailored Solutions for Every Growth Stage"
    subtitle="From local innovators to national enterprises, our agentic AI models scale to your needs with precision and security."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'Sarawak-based SMEs',
        description:
          'Digital transformation made accessible. Unlock enterprise-grade software development at affordable rates, leveling the playing field against bigger competitors.',
        icon: 'carbon:store',
      },
      {
        title: 'Tech Startups',
        description:
          'Accelerate your MVP. Leverage our autonomous agents to iterate fast, test continuously, and launch your product with "Software at the Speed of Thought".',
        icon: 'carbon:rocket',
      },
      {
        title: 'GLC & Enterprise',
        description:
          'Digital Sovereignty assured. We use a Google Cloud + Cloudflare Shield setup to keep data local while protected by global-grade firewalls.',
        icon: 'carbon:building-insights-2',
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/agentic_ai_advantage.png',
      alt: 'Agentic AI Development',
    }}
    title="The Agentic Advantage"
    subtitle="Why our AI-driven system is superior to traditional development teams."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Agentic Development</span>',
        description:
          'Forget managing a team of 5 seniors. Our AI-driven autonomous system builds software with unparalleled speed and consistency, eliminating human error.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: 'Step 2: <span class="font-medium">24/7 Self-Healing</span>',
        description:
          'Our software lives on Cloud Workstations that act as an immune system. They continually monitor, test, and "self-heal" your application day and night.',
        icon: 'carbon:security',
      },
      {
        title: 'Step 3: <span class="font-medium">Infrastructure Shield</span>',
        description:
          'Hosted on Google Cloud with a Cloudflare Shield. We ensure low latency by keeping data in Singapore/KL regions, honoring Digital Sovereignty.',
        icon: 'carbon:cloud-satellite',
      },
      {
        title: 'Step 4: <span class="font-medium">Cost-Efficient Scaling</span>',
        description:
          'Scale your technical capabilities without the overhead of hiring, insurance, or office space. Pay for performance and results.',
        icon: 'carbon:chart-line',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
