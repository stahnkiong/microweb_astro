---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero3 from '~/components/widgets/Hero3.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';

const metadata = {
  title: 'WhatsApp AI Agents, Custom VPS & Self-Hosted LLM Infrastructure | MicroWeb',
  description:
    'Deploy zero-friction WhatsApp AI agents. From serverless Firebase pipelines to custom Linux VPS environments running self-hosted local LLMs/LRMs for absolute data sovereignty.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero3
    actions={[{ variant: 'primary', text: 'Deploy Private AI Infrastructure', href: '#contact' }]}
    image={{
      src: '~/assets/images/custom_web_application_developement.webp',
      alt: 'System architecture blueprint detailing isolated Linux VPS infrastructure hosting open-source LLM networks and WhatsApp webhooks',
    }}
  >
    <Fragment slot="title">
      WhatsApp AI Agents Backed by <br />
      <span class="text-primary text-gradient highlight tracking-tight">Self-Hosted LLM & Custom VPS</span> Environments
    </Fragment>

    <Fragment slot="subtitle">
      Stop wasting corporate budget on unpredictable third-party API tokens and leaky external cloud networks. We
      engineer high-throughput WhatsApp Cloud API middleware powered by your choice of architecture: lightweight
      serverless Firebase pipelines, or dedicated custom Linux VPS bare-metal nodes hosting private, open-source Large
      Language Models (LLMs) and Large Reasoning Models (LRMs). Complete data sovereignty, zero adoption friction, and
      instant execution.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={3}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Custom Linux VPS<br/>Bare-Metal Configs',
            icon: 'carbon:virtual-private-cloud',
          },
          {
            description: 'Self-Hosted Private<br/>LLM & LRM Clusters',
            icon: 'carbon:machine-learning-model',
          },
          {
            description: 'Absolute Local<br/>Data Sovereignty',
            icon: 'carbon:security',
          },
          {
            description: 'Computer-Vision<br/>Photo Parsing',
            icon: 'carbon:image-search',
          },
          {
            description: 'Instant Lead Tracking<br/>(Zero-Cold Phase)',
            icon: 'carbon:flash',
          },
          {
            description: 'Direct Backend<br/>ERP Automation',
            icon: 'carbon:app-connectivity',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div
        class="absolute inset-0 grid grid-cols-2 -space-x-52 backdrop-blur-xl md:backdrop-blur-2xl backdrop-hue-rotate-180 backdrop-brightness-125 backdrop-contrast-[0.9]"
      >
        <div class="blur-[106px] h-64 bg-gradient-to-br from-yellow-100 to-violet-500 md:to-sky-300 dark:from-blue-700">
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-purple-300 to-cyan-300 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero3>

  <Banners2 />

  <Features5
    id="features"
    tagline="Private Agentic Ecosystems"
    columns={2}
    title="Uncompromising Performance Built on Sovereign Infrastructure"
    subtitle="We don't tie your business logic to fragile public web tools. We deploy independent computational backends designed to eliminate technical debt and automate human workloads natively inside WhatsApp."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'Self-Hosted Local LLM & LRM Deployments',
        description:
          'We free your enterprise from per-token SaaS pricing models. By deploying and fine-tuning open-source models natively on specialized compute layers, we establish a permanent AI asset that handles deep conversational reasoning, vector embeddings, and contextual intent processing internally.',
        icon: 'carbon:code',
      },
      {
        title: 'Custom Linux VPS Environments from Scratch',
        description:
          'For organizations demanding strict data isolation, we provision and harden dedicated Virtual Private Servers (VPS) from the OS layer up. We program your entire messaging middleware, caching arrays, and local data nodes with zero external software dependencies.',
        icon: 'carbon:server-dns',
      },
      {
        title: 'Instant Image-to-Data Parsing',
        description:
          'Manual data typing introduces errors and delays. Our integration allows delivery drivers, clients, or warehouse teams to snap a photo of a physical receipt or invoice sheet inside WhatsApp, using computer vision to instantly map parameters straight to your system databases.',
        icon: 'carbon:document-view',
      },
      {
        title: 'Non-Cold Lead Conversion Loops',
        description:
          'When an inbound prospect requests service details, manual tracking delays allow their intent to chill. Our autonomous conversational middleware captures, qualifies, and logs lead metrics instantly inside chat, moving hot prospects to your reps in real time.',
        icon: 'carbon:flash',
      },
      {
        title: 'Serverless Firebase Micro-Pipelines',
        description:
          'When target projects require hyper-focused operational execution without dedicated infrastructure costs, we utilize serverless Firebase Cloud Functions. The environment automatically scales horizontally during traffic spikes and operates with zero maintenance overhead.',
        icon: 'carbon:cloud-service-management',
      },
      {
        title: 'Automated ERP & Core Database Commits',
        description:
          'Bypass human middleware bottlenecks entirely. Once our parsing layers extract and validate transaction parameters from inbound customer messages, data payloads are securely pushed straight into your legacy ERP ledger via transactional-safe REST/GraphQL APIs.',
        icon: 'carbon:data-share',
      },
      {
        title: 'Contextual Multi-Turn Conversation Logic',
        description:
          'Our agentic workflows move far beyond primitive, rigid keyword match rules. We map out robust conversational state machines that understand complex, multi-turn human dialogue variations, maintaining memory context and parameters across long-form interactions.',
        icon: 'tabler:messages',
      },
      {
        title: 'Isolated Perimeter Security & Cloudflare Shield',
        description:
          'Whether running on serverless clusters or custom VPS setups, your production environment remains completely hidden from direct public access. Webhook traffic must cross an aggressive enterprise Cloudflare verification layer before communicating with internal systems.',
        icon: 'carbon:security',
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/process.webp',
      alt: 'MicroWeb systems engineers compiling custom Linux backend kernels and fine-tuning local model weights',
    }}
    title="Velocity Over Elegance: Infrastructure Deployment"
    subtitle="We launch your communication automation following strict validation loops, ensuring production speed over abstract over-engineering."
    items={[
      {
        title: 'Stage 1: Deconstruct Workflows & Data Scopes',
        description:
          'We analyze your manual administrative logs to map out the exact data collection sequences that cause structural operational delays.',
        icon: 'carbon:forum',
      },
      {
        title: 'Stage 2: Provision & Harden the Environment',
        description:
          'We deploy your dedicated compute stack, configuring serverless endpoints or spinning up a clean Linux VPS optimized for hosting local data nodes.',
        icon: 'carbon:devices',
      },
      {
        title: 'Stage 3: Instantiate local Models & Vision Engines',
        description:
          'We wire up your custom, self-hosted LLM/LRM weights and configure the computer-vision pipelines to handle automated image asset extraction.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: 'Stage 4: Hardwire Core Backend System Hooks',
        description:
          'We connect the WhatsApp Cloud API webhook layer, routing validated operational payloads directly into your core business ERP databases.',
        icon: 'carbon:cloud-data-ops',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
