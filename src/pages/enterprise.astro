---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Features5 from '~/components/widgets/Features5.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Portfoliosummary from '~/components/blog/PortFolioSummary.astro';
import Stats2 from '~/components/widgets/Stats2.astro';
import ContentContact from '~/components/widgets/ContentContact.astro';
import Headline from '~/components/ui/Headline.astro';

// Automated Asset Ingestion for the Tech Stack Tracker
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/stack/*');
const imagePaths = Object.keys(images).filter((imagePath) => {
  return imagePath.startsWith(`/src/assets/images/stack`);
});

// Global Metadata Configuration targeting High-Tier Compute Search Intent
const metadata = {
  ignoreTitleTemplate: true,
  title: 'Custom VPS, Private LLM Nodes & AI Infrastructure | MicroWeb Sarawak',
  description:
    'Deploy zero-friction WhatsApp AI agents backed by dedicated compute nodes. We engineer secure Linux VPS environments and fine-tune self-hosted local LLMs/LRMs for absolute corporate data sovereignty.',
};
---

<Layout metadata={metadata}>
  <ThreeJs />

  <!-- SECTION 1: HERO (The Tactical Hook - Unique Content) -->
  <Hero2
    tagline="Private Agentic Ecosystems & Dedicated Compute"
    actions={[{ variant: 'primary', text: 'Deploy Private AI Infrastructure', href: '#contact' }]}
    image={{
      src: '~/assets/images/custom_web_application_developement.webp',
      alt: 'System architecture blueprint detailing isolated Linux VPS infrastructure hosting open-source LLM networks and secure WhatsApp Cloud API webhooks',
    }}
  >
    <Fragment slot="title">
      WhatsApp AI Agents Backed by <br />
      <span class="text-primary text-gradient highlight tracking-tight">Self-Hosted LLM & Custom VPS</span> Environments
    </Fragment>

    <Fragment slot="subtitle">
      Stop wasting corporate budget on unpredictable third-party API tokens and leaky external cloud networks. We
      engineer high-throughput WhatsApp Cloud API middleware powered by your choice of architecture: lightweight
      serverless Firebase pipelines, or dedicated custom Linux VPS bare-metal nodes hosting private, open-source Large
      Language Models (LLMs) and Large Reasoning Models (LRMs). Complete data sovereignty, zero adoption friction, and
      instant execution across Malaysia.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Custom Linux VPS<br/>Bare-Metal Configs',
            icon: 'carbon:virtual-private-cloud',
          },
          {
            description: 'Self-Hosted Private<br/>LLM & LRM Clusters',
            icon: 'carbon:machine-learning-model',
          },
          {
            description: 'Absolute Local<br/>Data Sovereignty',
            icon: 'carbon:security',
          },
          {
            description: 'Computer-Vision<br/>Photo Parsing',
            icon: 'carbon:image-search',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-300 to-purple-500 md:to-purple-300 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-300 to-sky-200 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>

  <Banners2 />

  <!-- SECTION 2: SYSTEM CAPACITY METRICS (Computational Runtime Telemetry) -->
  <Stats2
    stats={[
      { title: 'Model Token Pricing Overhead', amount: '0.00%' },
      { title: 'Context Buffer Retention', amount: '100%' },
      { title: 'Data Transmission Path', amount: 'Isolated' },
    ]}
  />

  <!-- SECTION 3: ARCHITECTURAL PARAMETERS (Symmetric 8-Item Core Grid - Unique Infrastructure Context) -->
  <Features2
    id="features"
    tagline="Private Compute Vectors"
    title="Uncompromising Operational Performance Built on Sovereign Infrastructure"
    subtitle="We do not tie your business logic to fragile public web tools. We deploy independent computational backends designed to eliminate technical debt and automate human workloads natively inside WhatsApp."
    columns={2}
    items={[
      {
        title: 'Self-Hosted Local LLM & LRM Deployments',
        description:
          'We free your enterprise from unpredictable per-token SaaS pricing models. By deploying and fine-tuning open-source models natively on specialized local compute layers, we establish a permanent corporate AI asset that handles deep conversational reasoning, vector embeddings, and contextual intent processing internally.',
        icon: 'carbon:code',
      },
      {
        title: 'Custom Linux VPS Environments from Scratch',
        description:
          'For organizations demanding strict data isolation, we provision and harden dedicated Virtual Private Servers (VPS) from the OS layer up. We program your entire messaging middleware, caching arrays, and local data nodes with zero external software dependencies.',
        icon: 'carbon:server-dns',
      },
      {
        title: 'Instant Image-to-Data Parsing Pipelines',
        description:
          'Manual data typing introduces errors and operational delays. Our integration allows delivery drivers, clients, or warehouse teams to snap a photo of a physical receipt or invoice sheet inside WhatsApp, using advanced computer vision models to instantly map parameters straight to your system databases.',
        icon: 'carbon:document-view',
      },
      {
        title: 'Non-Cold Lead Conversion Loops',
        description:
          'When an inbound prospect requests service details, manual tracking delays allow their intent to chill. Our autonomous conversational middleware captures, qualifies, and logs lead metrics instantly inside chat, moving hot prospects to your reps in real time.',
        icon: 'carbon:flash',
      },
      {
        title: 'Serverless Firebase Micro-Pipelines',
        description:
          'When target projects require hyper-focused operational execution without dedicated infrastructure costs, we utilize serverless Firebase Cloud Functions. The environment automatically scales horizontally during traffic spikes and operates with zero maintenance overhead.',
        icon: 'carbon:cloud-service-management',
      },
      {
        title: 'Automated ERP & Core Database Commits',
        description:
          'Bypass human middleware bottlenecks entirely. Once our parsing layers extract and validate transaction parameters from inbound customer messages, data payloads are securely pushed straight into your legacy ERP ledger via transactional-safe REST/GraphQL APIs.',
        icon: 'carbon:data-share',
      },
      {
        title: 'Contextual Multi-Turn Conversation Logic',
        description:
          'Our agentic workflows move far beyond primitive, rigid keyword match rules. We map out robust conversational state machines that understand complex, multi-turn human dialogue variations, maintaining memory context and parameters across long-form interactions.',
        icon: 'tabler:messages',
      },
      {
        title: 'Isolated Perimeter Security & Cloudflare Shield',
        description:
          'Whether running on serverless clusters or custom VPS setups, your production environment remains completely hidden from direct public access. Webhook traffic must cross an aggressive enterprise Cloudflare verification layer before communicating with internal systems.',
        icon: 'carbon:security',
      },
    ]}
  />

  <!-- SECTION 4: VERTICAL INDUSTRIAL TARGETS (Enterprise Resource Application) -->
  <Features4
    id="sectors"
    tagline="Enterprise Node Deployment"
    columns={3}
    title="Deploying Sovereign Compute Assets Across Key Frameworks"
    subtitle="We replace unstable public wrappers with hardened, high-availability data backends optimized for regional transaction velocities."
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'Government & GLC Portal Nodes',
        description:
          'Secure, high-availability digital solutions built for localized data compliance guidelines and public verification logs.',
        link: '/clients/behind-scekl25/',
        icon: 'carbon:building-insights-3',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'Headless B2B Supply Networks',
        description:
          'Decoupled marketplace engines and secure inventory tracking ledger pipelines integrated straight with custom software wrappers.',
        link: '/clients/architecting-persistent-b2b-supply-chain-medusajs-docker/',
        icon: 'carbon:delivery-truck',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
      {
        title: 'High-Volume Sales Integration',
        description:
          'Conversion-rate optimized product architectures built for sub-second page delivery and custom enterprise web design frameworks.',
        link: '/clients/bosoffice/',
        icon: 'carbon:network-enterprise',
        callToAction: {
          variant: 'link',
          class: 'text-white bg-black/15 dark:bg-white/10 gotolink p-1.5 pb-[7px] rounded-full',
          icon: 'carbon:arrow-right',
        },
      },
    ]}
  />

  <!-- SECTION 5: THE TECHNICAL DEVELOPMENT STEPS (Modular Phases) -->
  <Steps3
    image={{
      src: '~/assets/images/process.webp',
      alt: 'MicroWeb systems engineers compiling custom Linux backend kernels and fine-tuning local model weights',
    }}
    title="Velocity Over Elegance: Infrastructure Deployment"
    subtitle="We launch your communication automation following strict validation loops, ensuring production speed over abstract over-engineering."
    items={[
      {
        title: 'Stage 1: Deconstruct Workflows & Data Scopes',
        description:
          'We analyze your manual administrative logs to map out the exact data collection sequences that cause structural operational delays.',
        icon: 'carbon:forum',
      },
      {
        title: 'Stage 2: Provision & Harden the Environment',
        description:
          'We deploy your dedicated compute stack, configuring serverless endpoints or spinning up a clean Linux VPS optimized for hosting local data nodes securely.',
        icon: 'carbon:devices',
      },
      {
        title: 'Stage 3: Instantiate local Models & Vision Engines',
        description:
          'We wire up your custom, self-hosted LLM/LRM weights and configure the computer-vision pipelines to handle automated image asset extraction.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: 'Stage 4: Hardwire Core Backend System Hooks',
        description:
          'We connect the WhatsApp Cloud API webhook layer, routing validated operational payloads directly into your core business custom software or ERP databases.',
        icon: 'carbon:cloud-data-ops',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <!-- SECTION 6: INTEGRATION VECTOR STACK (Sovereignty & Tooling Layers Proof) -->
  <section
    class="opacity-80 border-t border-b backdrop-blur-lg border-white/10 bg-neutral-50 dark:bg-neutral-900/30 not-prose py-16"
  >
    <div class="text-center mb-12">
      <Headline
        title="Sovereign Infrastructure Compute & Tooling Layers"
        subtitle="We bypass variable third-party API models entirely. We design, host, and monitor private network runtimes tailored for local digital data isolation guidelines."
        classes={{
          title: 'text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 dark:text-white',
          subtitle: 'text-neutral-500 dark:text-neutral-400 mt-2 max-w-2xl mx-auto',
        }}
      />
    </div>
    <div class="max-w-5xl mx-auto text-xs font-medium uppercase">
      <div
        class="px-8 grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-8 md:gap-12 items-center justify-items-center brightness-0 grayscale dark:invert opacity-60"
      >
        {
          imagePaths.map(async (imagePath) => {
            const image = images[imagePath]();
            const imageAlt = imagePath.split('/').pop()?.split('.').shift() || 'Technical stack integration token';
            return (
              <Image
                src={image}
                alt={`${imageAlt} private infrastructure node token - MicroWeb Sarawak`}
                loading="lazy"
                height={32}
                widths={[400, 768]}
                class="object-contain transition-all hover:opacity-100"
              />
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- SECTION 7: PRODUCTION CLIENT PROOF (Nested low to protect unique content sequence) -->
  <Portfoliosummary />

  <!-- SECTION 8: OPTIMIZED SILO INTAKE GATEWAY (Highly Focused Infrastructure Scope) -->
  <ContentContact id="contact">
    <Fragment slot="content">
      <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl">
        Deploy Private Computational Infrastructure
      </h2>
      <p class="mt-2 md:mt-4 text-lg font-semibold text-primary dark:text-accent">
        Establish an unvulnerable, self-hosted AI automation footprint inside your own security boundary.
      </p>
      <p class="mt-2 md:mt-4 text-neutral-600 dark:text-neutral-400">
        Stop leasing fragile chat workflows that leak internal business data metrics to third-party cloud aggregators.
        We engineer dedicated custom Linux VPS architectures and fine-tune private LLM/LRM deployments to process
        conversational logic natively, eliminating per-token pricing dependencies permanently while safeguarding your
        digital sovereignty behind an enterprise edge perimeter.<br />
        <strong
          >Let's execute — Contact our system architect team today to organize a technical hardware scoping audit.</strong
        >
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-white/40 dark:bg-neutral-950/20"></div>
    </Fragment>
  </ContentContact>
</Layout>
