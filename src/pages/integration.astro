---
import Layout from '~/layouts/PageLayout.astro';
import ThreeJs from '~/components/widgets/ThreeJs.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Banners2 from '~/components/widgets/Banners2.astro';
import Features4 from '~/components/widgets/Features4.astro';
import Steps3 from '~/components/widgets/Steps3.astro';
import Features5 from '~/components/widgets/Features5.astro';
import FollowUp from '~/components/widgets/FollowUp.astro';

const metadata = {
  ignoreTitleTemplate: true,
  title: 'Enterprise System Integration & Custom API Development | MicroWeb',
  description:
    'Bridge legacy database environments with modern cloud infrastructure. We engineer secure, decoupled API middleware, webhook orchestrations, and automated data synchronization pipelines.',
};
---

<Layout metadata={metadata}>
  <ThreeJs />
  <Hero2
    tagline="Enterprise System Integration & Custom API Development"
    actions={[{ variant: 'primary', text: 'Request Integration Audit', href: '#contact' }]}
    image={{
      src: '~/assets/images/integration_2.webp',
      alt: 'Architecture layout showing decoupled API middleware endpoints and secure network routing metrics',
    }}
  >
    <Fragment slot="title">
      Decoupled <span class="text-primary text-gradient highlight tracking-tight">API Middleware</span> & Enterprise System
      Integrations
    </Fragment>

    <Fragment slot="subtitle">
      Eliminate broken data dependencies and manual processing silos. We engineer secure, high-throughput API layers
      that safely connect legacy backends with modern cloud infrastructure, serverless edge networks, and instant
      messaging channels.
    </Fragment>
    <Fragment slot="content">
      <Features5
        columns={4}
        classes={{ container: 'py-8' }}
        items={[
          {
            description: 'Asynchronous<br/>Data Sync',
            icon: 'carbon:cloud-ceiling',
          },
          {
            description: 'Bespoke API<br/>Engineering',
            icon: 'carbon:api',
          },
          {
            description: 'Decoupled Third-Party<br/>Webhooks',
            icon: 'carbon:app-connectivity',
          },
          {
            description: 'Zero-Management<br/>Automation',
            icon: 'carbon:pricing-consumption',
          },
        ]}
      />
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute bg-page inset-0 grid grid-cols-2 -space-x-52 opacity-80 md:opacity-85">
        <div
          class="blur-[106px] h-64 bg-gradient-to-br from-violet-200 to-purple-600 md:to-purple-400 dark:from-blue-700"
        >
        </div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-100 to-cyan-300 dark:to-indigo-600"></div>
      </div>
    </Fragment>
  </Hero2>
  <Banners2 />

  <Features4
    id="features"
    tagline="Ecosystem Architecture"
    columns={3}
    title="Unified Data Environments, Managed Risk"
    subtitle="Break free from fragile, hardcoded point-to-point connections. Our custom middleware orchestrates data flow patterns across your entire stack:"
    classes={{ container: 'py-20 mt-80 md:mt-0 bg-white/80 md:bg-transparent dark:bg-black/80 dark:md:bg-transparent' }}
    items={[
      {
        title: 'ERP & Legacy Inventory Links',
        description: 'Connecting underlying product databases directly to high-velocity headless commerce storefronts.',
        link: '/clients/architecting-persistent-b2b-supply-chain-medusajs-docker',
        icon: 'carbon:network-enterprise',
      },
      {
        title: 'Hardware Telemetry Pipelines',
        description:
          'Ingesting raw edge metrics from low-level BLE beacon arrays and physical IoT signages into remote cloud environments.',
        link: '/clients/bluetooth-beacon-border-control',
        icon: 'carbon:sales-ops',
      },
      {
        title: 'Automated Account Routing',
        description:
          'Bridging front-end payment actions with legacy enterprise accounting suites via secure, transaction-safe ledgers.',
        link: '/clients/bosoffice',
        icon: 'carbon:finance',
      },
      {
        title: 'WhatsApp-to-Database Bridges',
        description:
          'Converting raw mobile photo assets into structured server variables natively using computer-vision pipelines.',
        icon: 'carbon:id-management',
      },
      {
        title: 'High-Velocity Content Schemas',
        description:
          'Synchronizing complex state payloads across distributed client viewports during high-traffic launch windows.',
        link: '/clients/behind-scekl25',
        icon: 'carbon:analytics-custom',
      },
      {
        title: 'Secure Identity Ingestion',
        description:
          'Deploying encrypted token exchanges and strict JWT validation protocols to govern external API access paths.',
        icon: 'carbon:chart-multitype',
      },
    ]}
  />

  <Steps3
    image={{
      src: '~/assets/images/integration.png',
      alt: 'MicroWeb integration engineers mapping out data transformation logic and webhook event pipelines',
    }}
    title="Velocity Over Elegance: Our Integration Framework"
    subtitle="We minimize deployment shock by executing your integration sequence in modular phases, ensuring continuous data availability."
    items={[
      {
        title: 'Stage 1: Deconstruct Data Schema Blocks',
        description:
          'We document and audit your current system schemas, mapping underlying table relations and dependency constraints.',
        icon: 'carbon:forum',
      },
      {
        title: 'Stage 2: Blueprint Middleware Mappings',
        description:
          'We outline the transactional path routing, specifying error handling rules and data caching policies.',
        icon: 'carbon:devices',
      },
      {
        title: 'Stage 3: Automated Micro-Code Compiles',
        description:
          'We develop the integration bridges using isolated service modules, validated by automated continuous testing suites.',
        icon: 'carbon:ibm-watsonx-code-assistant',
      },
      {
        title: 'Stage 4: Edge Runtime Orchestration',
        description:
          'We deploy the completed API layers behind an enterprise Cloudflare perimeter, monitoring active packet flows.',
        icon: 'carbon:cloud-data-ops',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 backdrop-blur-lg bg-black/70 dark:bg-black/30"></div>
    </Fragment>
  </Steps3>

  <FollowUp />
</Layout>
